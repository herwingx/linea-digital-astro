---
// src/components/ui/Button.astro
interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost" | "glass";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  onclick?: string;
  target?: string;
  rel?: string;
  id?: string;
  disabled?: boolean;
  "aria-label"?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  class: className,
  type = "button",
  ...rest
} = Astro.props;

const baseStyles =
  "inline-flex items-center justify-center gap-2 rounded-full font-bold transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none disabled:grayscale";

const variants = {
  primary:
    "bg-blue-600 text-white shadow-lg shadow-blue-600/30 hover:bg-blue-500 hover:shadow-blue-600/40 hover:-translate-y-0.5 border-t border-white/20 ring-1 ring-inset ring-black/5 dark:ring-white/10",

  secondary:
    "bg-white text-slate-700 border border-slate-200 shadow-sm hover:border-blue-300 hover:text-blue-600 hover:bg-slate-50 dark:bg-white/5 dark:text-slate-200 dark:border-white/10 dark:hover:bg-white/10 dark:hover:border-white/20 backdrop-blur-sm",

  outline:
    "border border-slate-300 text-slate-700 hover:border-blue-600 hover:text-blue-600 hover:bg-blue-50/50 dark:border-slate-600 dark:text-slate-300 dark:hover:border-blue-400 dark:hover:text-blue-400 dark:hover:bg-blue-900/10",

  ghost:
    "text-slate-600 hover:text-blue-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-blue-400 dark:hover:bg-white/5",

  // Nuevo: Para usar sobre fondos oscuros o imágenes
  glass:
    "bg-white/10 text-white border border-white/20 backdrop-blur-md hover:bg-white/20 shadow-lg shadow-black/5",
};

const sizes = {
  sm: "px-4 py-2 text-xs",
  md: "px-6 py-3 text-sm",
  lg: "px-8 py-4 text-base",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  class:list={[baseStyles, variants[variant], sizes[size], className]}
  {...rest}
>
  <slot />
</Tag>
