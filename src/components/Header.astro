---
import { Image } from "astro:assets";
import logoWhite from "../assets/logo-white.svg";
import logoDark from "../assets/logo-dark.svg";
import DarkModeToggle from "./DarkModeToggle.astro";

const { pathname } = Astro.url;

const isActive = (href: string) => {
  if (href === "/" && pathname === "/") return true;
  return href !== "/" && pathname.startsWith(href);
};

const navLinks = [
  {
    label: "Planes",
    href: "#",
    children: [
      { label: "Personas", href: "/personas", desc: "Datos ilimitados y redes" },
      { label: "Empresas", href: "/empresas", desc: "Soluciones corporativas" },
    ]
  },
  { label: "Promociones", href: "/promociones" },
  { label: "Asociados", href: "/asociados" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Contacto", href: "/contacto" },
];
---

<header
  id="main-header"
  class="fixed top-0 left-0 w-full z-[100] transition-all duration-300"
>
  <!-- Background Backdrop -->
  <div 
    id="header-bg" 
    class="absolute inset-0 bg-transparent backdrop-blur-[0px] border-b border-transparent transition-all duration-300 -z-10"
  ></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative flex items-center justify-between h-20 transition-all duration-300" id="header-container">
        
      <!-- 1. LOGO -->
      <div class="flex-shrink-0 relative z-[110]">
        <a href="/" class="block group" aria-label="Inicio">
           <Image src={logoWhite} alt="Logo" class="w-32 h-auto hidden dark:block transition-transform group-hover:scale-105" loading="eager" />
           <Image src={logoDark} alt="Logo" class="w-32 h-auto dark:hidden transition-transform group-hover:scale-105" loading="eager" />
        </a>
      </div>

      <!-- 2. DESKTOP NAV (Visible lg+) -->
      <nav class="hidden lg:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-20">
        <ul class="flex items-center gap-1 p-1.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border border-slate-200/50 dark:border-white/10 shadow-sm ring-1 ring-black/5">
           {navLinks.map((link) => {
               const hasChildren = link.children && link.children.length > 0;
               const active = isActive(link.href) || (hasChildren && link.children?.some(c => isActive(c.href)));

               return (
                   <li class="relative group">
                       <a href={link.href} class={`flex items-center gap-1 px-5 py-2 rounded-full text-sm font-bold transition-all duration-300 ${active ? 'bg-white dark:bg-white/10 text-slate-900 dark:text-white shadow-sm' : 'text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400'}`}>
                           {link.label}
                           {hasChildren && <svg class="w-3 h-3 opacity-50 group-hover:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>}
                       </a>
                       
                       {/* Dropdown Desktop (Premium Glass) */}
                       {hasChildren && (
                           <div class="absolute top-full left-1/2 -translate-x-1/2 pt-5 w-72 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] transform origin-top scale-90 group-hover:scale-100 translate-y-2 group-hover:translate-y-0 z-50">
                               <div class="bg-white/90 dark:bg-[#0f172a]/95 backdrop-blur-2xl rounded-2xl shadow-2xl border border-slate-200/50 dark:border-white/10 p-2 ring-1 ring-black/5 overflow-hidden">
                                   {link.children?.map(child => (
                                       <a href={child.href} class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-slate-50 dark:hover:bg-white/5 transition-all duration-200">
                                           <div class="mt-0.5 flex-shrink-0 w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 flex items-center justify-center group-hover/item:scale-110 group-hover/item:bg-blue-100 dark:group-hover/item:bg-blue-900/40 transition-all">
                                               <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                           </div>
                                           <div>
                                               <div class="text-sm font-bold text-slate-900 dark:text-white group-hover/item:text-blue-600 transition-colors">{child.label}</div>
                                               <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-snug">{child.desc}</div>
                                           </div>
                                       </a>
                                   ))}
                               </div>
                           </div>
                       )}
                   </li>
               );
           })}
        </ul>
      </nav>

      <!-- 3. ACTIONS & HAMBURGER -->
      <div class="flex items-center gap-3 relative z-[110]">
         <div class="hidden sm:block"><DarkModeToggle /></div>
         
         <a href="https://www.mitelcel.com/mitelcel/login" target="_blank" class="hidden lg:inline-flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white transition-all bg-slate-900 rounded-full hover:bg-blue-600 hover:shadow-lg dark:bg-white dark:text-slate-900">
            Mi Telcel
         </a>

         <!-- Hamburger Button (Mobile) -->
         <button 
            id="mobile-menu-btn"
            class="lg:hidden relative z-50 w-12 h-12 flex items-center justify-center rounded-full transition-all duration-300 focus:outline-none touch-manipulation
                   bg-white/50 dark:bg-slate-900/50 backdrop-blur-md border border-slate-200/50 dark:border-white/10 shadow-sm
                   hover:scale-110 hover:bg-white dark:hover:bg-slate-800 hover:shadow-lg hover:border-blue-200 dark:hover:border-blue-500/30
                   active:scale-90"
            aria-label="Menú"
            aria-expanded="false"
         >
             <div class="w-5 h-3.5 flex flex-col justify-between relative overflow-visible pointer-events-none">
                 <span class="w-full h-0.5 bg-slate-900 dark:bg-white rounded-full transition-all duration-300 ease-[cubic-bezier(0.68,-0.6,0.32,1.6)] origin-center ham-line-1"></span>
                 <span class="w-full h-0.5 bg-slate-900 dark:bg-white rounded-full transition-all duration-300 ease-[cubic-bezier(0.68,-0.6,0.32,1.6)] ham-line-2"></span>
                 <span class="w-full h-0.5 bg-slate-900 dark:bg-white rounded-full transition-all duration-300 ease-[cubic-bezier(0.68,-0.6,0.32,1.6)] origin-center ham-line-3"></span>
             </div>
         </button>
      </div>
    </div>
  </div>

  <!-- 4. MOBILE MENU FLOATING DROPDOWN -->
  <div 
    id="mobile-menu-dropdown" 
    class="absolute top-[80px] left-0 right-0 mx-4 z-[100] origin-top transform transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] scale-95 opacity-0 invisible pointer-events-none"
  >
      <div class="bg-white/90 dark:bg-[#0f172a]/95 backdrop-blur-2xl rounded-[2rem] border border-slate-200/60 dark:border-white/10 shadow-2xl shadow-blue-900/20 overflow-hidden ring-1 ring-black/5">
          <nav class="flex flex-col p-2">
             {navLinks.map((link) => {
                 // CASE: Dropdown Mobile (Accordion)
                 if (link.children) {
                     return (
                         <div class="mobile-group">
                             <button 
                                class="flex items-center justify-between w-full px-5 py-4 text-left rounded-2xl hover:bg-slate-50 dark:hover:bg-white/5 transition-colors group mobile-accordion-trigger"
                                aria-expanded="false"
                             >
                                 <span class="font-bold text-slate-900 dark:text-white text-lg">{link.label}</span>
                                 <span class="w-8 h-8 rounded-full bg-slate-100 dark:bg-white/10 flex items-center justify-center group-hover:bg-blue-100 dark:group-hover:bg-blue-900 transition-colors">
                                     <svg class="w-4 h-4 text-slate-500 dark:text-slate-400 transition-transform duration-300 accordion-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                 </span>
                             </button>
                             
                             <!-- Submenu Animated Content -->
                             <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out mobile-accordion-grid">
                                 <div class="overflow-hidden">
                                     <div class="px-4 pb-2 space-y-1 bg-slate-50/50 dark:bg-black/20 rounded-xl mt-1 mx-2">
                                         {link.children.map(child => (
                                             <a href={child.href} class="flex items-center gap-3 w-full px-4 py-3 rounded-xl text-base font-medium text-slate-600 dark:text-slate-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-white dark:hover:bg-white/5 transition-all">
                                                 <span class="w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-slate-600"></span>
                                                 {child.label}
                                             </a>
                                         ))}
                                     </div>
                                 </div>
                             </div>
                         </div>
                     )
                 }
                 // CASE: Normal Link
                 const active = isActive(link.href);
                 return (
                     <a href={link.href} class={`flex items-center w-full px-5 py-4 rounded-2xl text-lg font-bold transition-all ${active ? 'bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5 hover:text-slate-900 dark:hover:text-white'}`}>
                         {link.label}
                     </a>
                 );
             })}
          </nav>

          <!-- Footer Actions -->
          <div class="p-4 border-t border-slate-100 dark:border-white/5 bg-slate-50/50 dark:bg-white/5 flex flex-col gap-3">
               <div class="flex items-center justify-between px-2">
                   <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">Preferencia de tema</span>
                   <DarkModeToggle />
               </div>
               <a href="https://www.mitelcel.com/mitelcel/login" target="_blank" class="w-full flex items-center justify-center py-3.5 rounded-xl bg-slate-900 dark:bg-blue-600 text-white font-bold shadow-lg shadow-slate-900/10 active:scale-95 transition-transform">
                   Ingresar a Mi Telcel
               </a>
          </div>
      </div>
  </div>
</header>

<style>
  /* Hamburger Animation (Elastic) */
  .menu-active .ham-line-1 { transform: translateY(6px) rotate(135deg); }
  .menu-active .ham-line-2 { opacity: 0; transform: scaleX(0); }
  .menu-active .ham-line-3 { transform: translateY(-6px) rotate(-135deg); }
  
  /* Active Button State */
  #mobile-menu-btn.menu-active {
      @apply bg-slate-900 dark:bg-white border-slate-900 dark:border-white;
  }
  #mobile-menu-btn.menu-active span {
      @apply bg-white dark:bg-slate-900;
  }

  /* Accordion Animation */
  .mobile-accordion-trigger[aria-expanded="true"] .accordion-icon {
      transform: rotate(180deg);
  }
  .mobile-accordion-trigger[aria-expanded="true"] {
      @apply bg-slate-50 dark:bg-white/5 text-blue-600 dark:text-blue-400;
  }
  .mobile-accordion-grid.open {
      grid-template-rows: 1fr;
  }
  
  /* Scroll State */
  .header-scrolled #header-bg {
     @apply bg-white/80 dark:bg-[#0f172a]/80 backdrop-blur-xl border-slate-200/60 dark:border-white/10 shadow-sm;
  }
  .header-scrolled #header-container {
     @apply h-16;
  }

  /* Dropdown Active State */
  .dropdown-active {
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: auto !important;
      transform: scale(100%) !important;
  }
</style>

<script>
    const setupHeader = () => {
        const header = document.getElementById("main-header");
        const btn = document.getElementById("mobile-menu-btn");
        const dropdown = document.getElementById("mobile-menu-dropdown");
        
        // 1. SCROLL EFFECT
        if (!header?.dataset.scrollInitialized) {
            const updateScroll = () => {
                if (window.scrollY > 20) {
                    header?.classList.add("header-scrolled");
                } else {
                    header?.classList.remove("header-scrolled");
                }
            };
            window.addEventListener("scroll", updateScroll);
            updateScroll();
            if(header) header.dataset.scrollInitialized = "true";
        }

        // 2. TOGGLE MENU LOGIC
        let isOpen = false;
        
        const closeMenu = () => {
            isOpen = false;
            btn?.classList.remove("menu-active");
            btn?.setAttribute("aria-expanded", "false");
            dropdown?.classList.remove("dropdown-active");
        };

        const toggleMenu = () => {
            isOpen = !isOpen;
            if (isOpen) {
                btn?.classList.add("menu-active");
                btn?.setAttribute("aria-expanded", "true");
                dropdown?.classList.add("dropdown-active");
            } else {
                closeMenu();
            }
        };

        if (btn && !btn.dataset.clickInitialized) {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                toggleMenu();
            });
            btn.dataset.clickInitialized = "true";
        }

        document.addEventListener("click", (e) => {
            if (isOpen && dropdown && !dropdown.contains(e.target as Node) && !btn?.contains(e.target as Node)) {
                closeMenu();
            }
        });

        // 3. ACCORDION SUBMENU LOGIC (Smooth Grid Animation)
        const triggers = document.querySelectorAll(".mobile-accordion-trigger");
        triggers.forEach(trigger => {
            if ((trigger as HTMLElement).dataset.accordionInitialized) return;
            
            trigger.addEventListener("click", function(this: HTMLElement) {
                const isExpanded = this.getAttribute("aria-expanded") === "true";
                this.setAttribute("aria-expanded", String(!isExpanded));
                
                const grid = this.nextElementSibling;
                if (grid) {
                    grid.classList.toggle("open");
                }
            });
            (trigger as HTMLElement).dataset.accordionInitialized = "true";
        });
        
        const links = dropdown?.querySelectorAll("a");
        links?.forEach(link => {
            link.addEventListener("click", closeMenu);
        });
    };

    document.addEventListener("astro:page-load", setupHeader);
</script>