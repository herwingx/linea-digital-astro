---
// src/components/FAQAccordion.astro
interface Props {
  items: {
    question: string;
    answer: string;
  }[];
}

const { items } = Astro.props;
---

<div class="flex flex-col gap-4">
  {items.map((item, index) => {
    // Generamos IDs únicos para accesibilidad
    const id = `faq-${Math.random().toString(36).substr(2, 9)}`;
    
    return (
      <div class="group rounded-2xl border border-slate-200 bg-white transition-all duration-300 hover:border-blue-300 hover:shadow-lg hover:shadow-blue-900/5 dark:border-white/5 dark:bg-slate-900/40 dark:hover:border-blue-500/30">
        <button
          type="button"
          class="faq-trigger flex w-full items-start justify-between gap-4 p-6 text-left focus:outline-none"
          aria-expanded="false"
          aria-controls={id}
        >
          <span class="text-base font-bold text-slate-800 transition-colors group-hover:text-blue-700 dark:text-slate-100 dark:group-hover:text-blue-400 sm:text-lg">
            {item.question}
          </span>
          
          <!-- Icono Animado -->
          <span class="relative ml-4 flex h-6 w-6 flex-shrink-0 items-center justify-center">
            <span class="absolute h-0.5 w-full bg-slate-400 transition-transform duration-300 group-hover:bg-blue-600 dark:bg-slate-500 dark:group-hover:bg-blue-400"></span> <!-- Horizontal -->
            <span class="vertical-bar absolute h-full w-0.5 bg-slate-400 transition-transform duration-300 group-hover:bg-blue-600 dark:bg-slate-500 dark:group-hover:bg-blue-400"></span> <!-- Vertical -->
          </span>
        </button>
        
        <div
          id={id}
          class="faq-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]"
        >
          <div class="overflow-hidden">
            <div class="px-6 pb-6 pt-0">
              <div class="prose prose-sm max-w-none border-t border-slate-100 pt-4 text-slate-600 dark:border-white/5 dark:text-slate-400">
                <p class="leading-relaxed">{item.answer}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    );
  })}
</div>

<script>
  // Lógica optimizada (Vanilla JS + Performance)
  document.addEventListener('astro:page-load', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        const content = btn.nextElementSibling;
        const verticalBar = btn.querySelector('.vertical-bar');

        // Toggle State
        btn.setAttribute('aria-expanded', (!isExpanded).toString());
        
        // CSS Grid Animation Trick (0fr -> 1fr)
        if (content) {
          content.classList.toggle('grid-rows-[1fr]');
          content.classList.toggle('grid-rows-[0fr]');
        }

        // Icon Rotation Logic
        if (verticalBar) {
          verticalBar.classList.toggle('rotate-90'); // Si rota 90, se alinea con la horizontal y parece un "-"
          verticalBar.classList.toggle('opacity-0'); // O simplemente ocultamos la vertical para hacer un "-"
        }
        
        // Opcional: Colorear el borde activo
        btn.parentElement?.classList.toggle('ring-1');
        btn.parentElement?.classList.toggle('ring-blue-500');
        btn.parentElement?.classList.toggle('border-blue-500');
      });
    });
  });
  
  // Fallback inicial
  if (document.readyState === 'complete') document.dispatchEvent(new Event('astro:page-load'));
  else document.addEventListener('DOMContentLoaded', () => document.dispatchEvent(new Event('astro:page-load')));
</script>