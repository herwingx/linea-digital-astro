---
// src/components/Newsletter.astro
---

<section class="relative py-16 sm:py-24 px-4 sm:px-6 overflow-hidden">
  <!-- Contenedor Principal con Efecto Glass/Tech -->
  <div
    class="relative mx-auto max-w-7xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl shadow-slate-200/50 dark:border-slate-800 dark:bg-slate-900/80 dark:shadow-blue-900/20 backdrop-blur-xl transition-colors duration-500"
  >
    <!-- 1. CAPA DE FONDO (Technical Grid) -->
    <div class="absolute inset-0 pointer-events-none">
      <!-- Grid Pattern -->
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"
      >
      </div>

      <!-- Glow Effects (Sutiles) -->
      <div
        class="absolute -left-[10%] top-[-10%] h-[500px] w-[500px] rounded-full bg-blue-600/10 blur-[100px] dark:bg-blue-600/20"
      >
      </div>
      <div
        class="absolute -right-[10%] bottom-[-10%] h-[400px] w-[400px] rounded-full bg-cyan-600/10 blur-[100px] dark:bg-cyan-600/20"
      >
      </div>
    </div>

    <!-- 2. LAYOUT DOS COLUMNAS -->
    <div class="relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-0">
      <!-- COLUMNA IZQUIERDA: Copywriting B2B -->
      <div
        class="flex flex-col justify-center sm:px-12 lg:py-16 lg:pr-0 bg-slate-50/50 px-8 py-12 dark:bg-slate-950/30"
      >
        <!-- Badge -->
        <div
          class="mb-6 inline-flex items-center gap-2 self-start rounded-lg border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue-700 dark:border-blue-900/50 dark:bg-blue-900/30 dark:text-blue-400"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-75"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-blue-500"
            ></span>
          </span>
          Boletín de Partners
        </div>

        <h2
          class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl lg:text-5xl"
        >
          Stock y precios <br />
          <span
            class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent"
            >directo a tu bandeja.</span
          >
        </h2>

        <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-md">
          Sé el primero en enterarte de la llegada de lotes de iPhone, cambios
          en esquemas de comisiones y promociones flash de Telcel.
        </p>

        <!-- Prueba Social B2B (Red de Distribuidores) -->
        <div class="mt-8 flex items-center gap-4">
          <div class="flex -space-x-3">
            <!-- Iconos abstractos de empresas/partners -->
            <div
              class="h-10 w-10 rounded-full border-2 border-white bg-slate-100 flex items-center justify-center text-slate-600 font-bold text-xs dark:border-slate-900 dark:bg-slate-800 dark:text-slate-400"
            >
              DG
            </div>
            <div
              class="h-10 w-10 rounded-full border-2 border-white bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-xs dark:border-slate-900 dark:bg-blue-900/30 dark:text-blue-400"
            >
              TC
            </div>
            <div
              class="h-10 w-10 rounded-full border-2 border-white bg-cyan-100 flex items-center justify-center text-cyan-600 font-bold text-xs dark:border-slate-900 dark:bg-cyan-900/30 dark:text-cyan-400"
            >
              MK
            </div>
          </div>
          <div class="text-sm">
            <p class="font-bold text-slate-900 dark:text-white">
              +2,500 Asociados
            </p>
            <p class="text-slate-500 dark:text-slate-500">
              reciben nuestras alertas diarias.
            </p>
          </div>
        </div>
      </div>

      <!-- COLUMNA DERECHA: Formulario -->
      <div
        class="relative flex flex-col justify-center bg-slate-50/50 px-8 py-12 dark:bg-slate-950/30 sm:px-12 lg:py-16"
      >
        <!-- Decoración de borde lateral en desktop -->
        <div
          class="absolute left-0 top-10 bottom-10 hidden w-px bg-gradient-to-b from-transparent via-slate-200 to-transparent dark:via-slate-800 lg:block"
        >
        </div>

        <form id="newsletter-form" class="w-full max-w-sm mx-auto lg:mx-0">
          <div class="flex flex-col gap-2 mb-2">
            <label
              for="email-address"
              class="text-sm font-semibold text-slate-700 dark:text-slate-300"
              >Correo Electrónico Comercial</label
            >

            <!-- Input Group -->
            <div class="relative group">
              <div
                class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
              >
                <svg
                  class="h-5 w-5 text-slate-400 group-focus-within:text-blue-500 transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>

              <input
                id="email-address"
                name="email"
                type="email"
                autocomplete="email"
                required
                class="block w-full rounded-xl border-0 py-3.5 pl-11 pr-4 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 dark:bg-slate-900 dark:text-white dark:ring-slate-700 dark:placeholder:text-slate-500 dark:focus:ring-blue-500 sm:text-sm sm:leading-6 transition-all"
                placeholder="contacto@tuempresa.com"
              />
            </div>
          </div>

          <!-- Botón con Estado -->
          <button
            type="submit"
            class="mt-4 w-full rounded-xl bg-blue-600 px-3.5 py-3.5 text-sm font-bold text-white shadow-lg shadow-blue-600/20 hover:bg-blue-500 hover:shadow-blue-600/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 disabled:opacity-70 disabled:cursor-not-allowed transition-all active:scale-[0.98]"
          >
            <span id="btn-text" class="flex items-center justify-center gap-2">
              Suscribirme
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
              >
            </span>
            <!-- Spinner Loader -->
            <svg
              id="btn-spinner"
              class="hidden h-5 w-5 animate-spin mx-auto text-white"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
          </button>

          <!-- Feedback Zone (Altura reservada para evitar saltos) -->
          <div class="mt-4 min-h-[1.5rem]">
            <p
              id="newsletter-feedback"
              class="text-xs font-medium text-center lg:text-left transition-all duration-300 opacity-0 translate-y-2"
            >
            </p>
          </div>

          <p
            class="mt-2 text-[11px] text-slate-500 dark:text-slate-500 text-center lg:text-left"
          >
            Sin spam. Cancelas con un clic. <a
              href="#"
              class="underline hover:text-blue-600 dark:hover:text-blue-400"
              >Privacidad</a
            >.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  let newsletterInitialized = false;

  function initNewsletter() {
    if (newsletterInitialized) return;
    newsletterInitialized = true;

    const form = document.getElementById("newsletter-form") as HTMLFormElement;
    const feedback = document.getElementById("newsletter-feedback");
    const input = document.getElementById("email-address") as HTMLInputElement;
    const btn = form?.querySelector("button");
    const btnText = document.getElementById("btn-text");
    const btnSpinner = document.getElementById("btn-spinner");

    if (!form || !btn || !btnText || !btnSpinner || !feedback) return;

    // Helper para mostrar mensajes
    const showMessage = (
      message: string,
      type: "success" | "error" | "info",
    ) => {
      let icon = "";
      let colorClass = "";

      if (type === "success") {
        icon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
        colorClass =
          "text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 px-3 py-2 rounded-lg border border-green-200 dark:border-green-900/30";
      } else if (type === "error") {
        icon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
        colorClass =
          "text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 px-3 py-2 rounded-lg border border-red-200 dark:border-red-900/30";
      } else if (type === "info") {
        // Para "Ya suscrito"
        icon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
        colorClass =
          "text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 px-3 py-2 rounded-lg border border-blue-200 dark:border-blue-900/30";
      }

      feedback.className = `flex items-center gap-2 text-xs font-medium justify-center lg:justify-start transition-all duration-300 translate-y-0 opacity-100 ${colorClass}`;
      feedback.innerHTML = `${icon} <span>${message}</span>`;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (btn.disabled) return;

      // Loading UI
      btn.disabled = true;
      btnText.classList.add("hidden");
      btnSpinner.classList.remove("hidden");
      feedback.classList.add("opacity-0", "translate-y-2"); // Ocultar mensaje previo suavemente

      try {
        const formData = new FormData(form);
        const response = await fetch("/api/subscribe", {
          method: "POST",
          body: formData,
        });
        const data = await response.json();

        if (response.ok) {
          const isAlreadySubscribed = data.message
            .toLowerCase()
            .includes("ya est");

          if (isAlreadySubscribed) {
            // Caso: YA SUSCRITO (Azul/Info)
            showMessage(
              "Este correo ya se encuentra en nuestra lista.",
              "info",
            );
            btn.classList.remove("bg-blue-600", "hover:bg-blue-500");
            btn.classList.add("bg-slate-700", "cursor-default");
            btnText.innerHTML = "Ya eres parte";
          } else {
            // Caso: NUEVA SUSCRIPCIÓN (Verde/Éxito)
            showMessage(
              "¡Registro exitoso! Revisa tu bandeja de entrada.",
              "success",
            );
            input.value = ""; // Limpiar solo si es nuevo

            // Botón de éxito
            btn.classList.remove(
              "bg-blue-600",
              "hover:bg-blue-500",
              "shadow-blue-600/20",
            );
            btn.classList.add(
              "bg-green-600",
              "hover:bg-green-500",
              "shadow-green-600/20",
              "pointer-events-none",
            );
            btnText.innerHTML = "Suscrito Correctamente";
          }

          // Restaurar loading
          btnSpinner.classList.add("hidden");
          btnText.classList.remove("hidden");

          // Reset parcial del botón después de unos segundos
          if (!isAlreadySubscribed) {
            setTimeout(() => {
              btn.disabled = false;
              btn.classList.remove(
                "bg-green-600",
                "hover:bg-green-500",
                "shadow-green-600/20",
                "pointer-events-none",
              );
              btn.classList.add(
                "bg-blue-600",
                "hover:bg-blue-500",
                "shadow-blue-600/20",
              );
              btnText.innerHTML = `Suscribirme <svg class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`;
              feedback.classList.add("opacity-0", "translate-y-2");
            }, 5000);
          } else {
            btn.disabled = false; // Permitir intentar con otro correo
          }
        } else {
          throw new Error(data.message || "Error al procesar");
        }
      } catch (error) {
        console.error(error);
        showMessage("Error de conexión. Intenta nuevamente.", "error");
        btn.disabled = false;
        btnSpinner.classList.add("hidden");
        btnText.classList.remove("hidden");
      }
    });
  }

  // Soporte para Astro View Transitions
  document.addEventListener("astro:page-load", initNewsletter);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNewsletter);
  } else {
    initNewsletter();
  }
</script>
