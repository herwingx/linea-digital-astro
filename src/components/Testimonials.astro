---
// src/components/Reviews.astro
import Button from "./ui/Button.astro";

// --- 1. DEFINICIÓN DE TIPOS ---
interface Review {
  author_name: string;
  profile_photo_url?: string | null;
  rating: number;
  text: string;
  relative_time_description: string;
  time?: number;
}

// --- 2. DATOS DE RESPALDO (FALLBACK) ---
// Optimizados para vender confianza B2B (Soporte, Rapidez, Stock)
const fallbackReviews: Review[] = [
  {
    author_name: "Constructora del Sur",
    profile_photo_url: null,
    rating: 5,
    text: "La implementación de la flotilla de líneas para nuestros ingenieros de campo fue inmediata. El portal de autogestión nos ahorra horas administrativas al mes.",
    relative_time_description: "Hace 2 semanas",
  },
  {
    author_name: "Carlos Rodríguez",
    profile_photo_url: null,
    rating: 5,
    text: "Excelente atención para distribuidores. Siempre tienen stock de los equipos de gama alta que mis clientes piden. La logística de entrega es impecable.",
    relative_time_description: "Hace 1 mes",
  },
  {
    author_name: "Farmacias San Pablo (Sucursal)",
    profile_photo_url: null,
    rating: 5,
    text: "Resolvieron nuestro problema de conectividad 4G en zonas rurales donde otros proveedores no llegaban. El soporte técnico realmente sabe lo que hace.",
    relative_time_description: "Hace 2 meses",
  },
];

// --- 3. LÓGICA DE API (Server Side) ---
const API_KEY = import.meta.env.GOOGLE_API_KEY;
const PLACE_ID = import.meta.env.GOOGLE_PLACE_ID;

let finalReviews: Review[] = [];

// Función para obtener iniciales
const getInitial = (name: string) => (name ? name.charAt(0).toUpperCase() : "C");

// Fetching de datos
if (API_KEY && PLACE_ID) {
  try {
    const url = `https://maps.googleapis.com/maps/api/place/details/json?place_id=${PLACE_ID}&fields=reviews&key=${API_KEY}&language=es`;
    const response = await fetch(url);
    const data = await response.json();

    if (data.result && data.result.reviews) {
      let googleReviews: Review[] = data.result.reviews;

      // Filtrado B2B: Solo reseñas de alta calidad (largas y positivas)
      googleReviews = googleReviews.filter(
        (review) =>
          review.rating >= 4 &&
          review.text &&
          review.text.length > 40 // Filtramos "Muy bien" o textos cortos que no aportan valor
      );

      // Ordenar por fecha (más reciente primero)
      googleReviews.sort((a, b) => (b.time || 0) - (a.time || 0));
      finalReviews = googleReviews;
    }
  } catch (error) {
    console.error("Error conectando a Google Reviews:", error);
    // Fallback silencioso
  }
}

// Relleno inteligente
const reviewsNeeded = 3;
if (finalReviews.length < reviewsNeeded) {
  finalReviews = [
    ...finalReviews,
    ...fallbackReviews.slice(0, reviewsNeeded - finalReviews.length),
  ];
} else {
  finalReviews = finalReviews.slice(0, 6); // Máximo 6 cards
}
---

<section class="relative overflow-hidden py-24 transition-colors duration-500">
  <div class="container relative z-10 mx-auto px-6 lg:px-8">
    
    <!-- HEADER -->
    <div class="mx-auto mb-20 max-w-3xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-blue-200/60 bg-white/80 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-blue-700 backdrop-blur-md dark:border-blue-800/50 dark:bg-blue-950/30 dark:text-blue-400 shadow-sm">
        <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Reputación Verificada
      </div>
      
      <h2 class="text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white md:text-5xl">
        La confianza se construye con resultados

      </h2>
      <p class="mt-6 text-xl leading-relaxed text-slate-600 dark:text-slate-400">
        No tomes solo nuestra palabra. Lee las experiencias de quienes ya han transformado su conectividad con nosotros.
      </p>
    </div>

    <!-- REVIEWS GRID (Bento Style Cards) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        finalReviews.map((review) => (
          <article class="group relative flex flex-col justify-between h-full rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-900/10 hover:border-blue-200 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-blue-800 dark:hover:bg-slate-800/50">
            
            <div>
              <!-- Header Card: Profile + Info -->
              <div class="flex items-center gap-4 mb-6">
                 <!-- Avatar Logic -->
                 <div class="relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-full ring-2 ring-white dark:ring-slate-800 shadow-md">
                    {review.profile_photo_url ? (
                      <img
                        src={review.profile_photo_url}
                        alt={review.author_name}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                        loading="lazy"
                      />
                    ) : (
                      <div class="h-full w-full bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900 dark:to-indigo-900 flex items-center justify-center">
                        <span class="text-lg font-bold text-blue-700 dark:text-blue-300">{getInitial(review.author_name)}</span>
                      </div>
                    )}
                 </div>
                 
                 <div>
                   <h3 class="text-base font-bold text-slate-900 dark:text-white leading-tight group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                     {review.author_name}
                   </h3>
                   <time class="text-xs font-medium uppercase tracking-wider text-slate-400 dark:text-slate-500">
                     {review.relative_time_description}
                   </time>
                 </div>
              </div>

              <!-- Content -->
              <div class="relative">
                <!-- Comillas decorativas -->
                <span class="absolute -top-2 -left-2 text-6xl text-slate-100 dark:text-slate-800 font-serif leading-none select-none -z-10 group-hover:text-blue-50 dark:group-hover:text-blue-900/20 transition-colors">“</span>
                <p class="relative z-10 text-base leading-relaxed text-slate-600 dark:text-slate-300 line-clamp-4 group-hover:line-clamp-none transition-all duration-300">
                  {review.text}
                </p>
              </div>
            </div>

            <!-- Footer Card: Rating + Platform -->
            <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
              <!-- Estrellas -->
              <div class="flex gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class={`h-4 w-4 ${i < review.rating ? "text-amber-400 fill-amber-400" : "text-slate-200 dark:text-slate-700 fill-slate-200 dark:fill-slate-700"}`}
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              <!-- Google Logo (Interactive Monochrome) -->
              <a href={`https://search.google.com/local/reviews?placeid=${PLACE_ID}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" title="Ver en Google">
                <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Verificado en</span>
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M23.766 12.2764C23.766 11.4607 23.6999 10.6406 23.5588 9.83807H12.24V14.4591H18.7217C18.4528 15.9494 17.5885 17.2678 16.323 18.1056V21.1039H20.19C22.4608 19.0139 23.766 15.9274 23.766 12.2764Z" fill="#4285F4"/>
                  <path d="M12.2401 24.0008C15.4766 24.0008 18.2059 22.9382 20.1945 21.1039L16.3275 18.1055C15.2517 18.8375 13.8627 19.252 12.2445 19.252C9.11388 19.252 6.45946 17.1399 5.50705 14.3003H1.5166V17.3912C3.55371 21.4434 7.7029 24.0008 12.2401 24.0008Z" fill="#34A853"/>
                  <path d="M5.50253 14.3003C5.00236 12.8099 5.00236 11.1961 5.50253 9.70575V6.61481H1.51649C-0.18551 10.0056 -0.18551 14.0004 1.51649 17.3912L5.50253 14.3003Z" fill="#FBBC04"/>
                  <path d="M12.2401 4.74966C13.9509 4.7232 15.6044 5.36697 16.8434 6.54867L20.2695 3.12262C18.1001 1.0855 15.2208 -0.0344664 12.2401 0.000808666C7.7029 0.000808666 3.55371 2.55822 1.5166 6.61481L5.50264 9.70575C6.45064 6.86173 9.10947 4.74966 12.2401 4.74966Z" fill="#EA4335"/>
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <!-- CTA FOOTER -->
    <div class="mt-16 flex flex-col items-center justify-center gap-4 text-center">
      <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
        ¿Eres cliente y quieres compartir tu experiencia?
      </p>
      <Button
        href={`https://search.google.com/local/writereview?placeid=${PLACE_ID}`}
        target="_blank"
        variant="secondary"
        size="md"
        class="gap-2 border-slate-200 dark:border-slate-700 dark:bg-slate-900"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
        Escribir una Reseña
      </Button>
    </div>
  </div>
</section>