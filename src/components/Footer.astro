---
// src/components/Footer.astro
import { Image } from "astro:assets";
import logoWhite from "../assets/logo-white.svg";
import logoDark from "../assets/logo-dark.svg";
import SocialIcon from "./SocialIcon.astro";
import Newsletter from "./Newsletter.astro";

const currentYear = new Date().getFullYear();

// Enlaces organizados por intención de usuario
const footerLinks = [
  {
    title: "Soluciones",
    links: [
      { label: "Planes Empresariales", href: "/empresas" },
      { label: "IoT & Telemetría", href: "/iot" },
      { label: "Telefonía Libre", href: "/equipos" },
      { label: "Internet en Casa", href: "/internet" },
    ],
  },
  {
    title: "Compañía",
    links: [
      { label: "Sobre Nosotros", href: "/nosotros" },
      { label: "Programa de Partners", href: "/asociados" },
      { label: "Bolsa de Trabajo", href: "/carreras" },
      { label: "Sala de Prensa", href: "/prensa" },
    ],
  },
  {
    title: "Recursos",
    links: [
      { label: "Centro de Ayuda", href: "/contacto" },
      { label: "Estado del Servicio", href: "/status" },
      { label: "Facturación", href: "/facturacion" },
      { label: "Guías de Configuración", href: "/guias" },
    ],
  },
];

const socialLinks = [
  { name: "Facebook", href: "https://facebook.com" },
  { name: "Instagram", href: "https://instagram.com" },
  { name: "X", href: "https://twitter.com" },
  { name: "LinkedIn", href: "https://linkedin.com" },
];
---

<footer
  class="relative w-full pt-24 pb-8 overflow-hidden bg-slate-50 dark:bg-slate-950 border-t border-slate-200 dark:border-slate-800"
>
  <!-- BACKGROUND PATTERN (Technical Grid) -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.03] dark:opacity-[0.05]"
    style="background-image: radial-gradient(#64748b 1px, transparent 1px); background-size: 24px 24px;"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 md:px-8">
    <!-- 1. NEWSLETTER FLOATING SECTION -->
    <div class="mb-24">
      <Newsletter />
    </div>

    <!-- 2. MAIN GRID -->
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-12 xl:gap-16 mb-20 border-b border-slate-200/60 pb-16 dark:border-slate-800/60"
    >
      <!-- BRAND COLUMN (4 cols) -->
      <div class="lg:col-span-4 flex flex-col justify-between h-full">
        <div class="space-y-6">
          <a
            href="/"
            class="inline-block transition-opacity hover:opacity-80"
            aria-label="Inicio"
          >
            <Image
              src={logoWhite}
              alt="Logo"
              class="w-40 h-auto hidden dark:block"
            />
            <Image src={logoDark} alt="Logo" class="w-40 h-auto dark:hidden" />
          </a>

          <p
            class="text-sm leading-relaxed text-slate-500 dark:text-slate-400 max-w-sm"
          >
            Distribuidor Autorizado Telcel con certificación Enterprise.
            Conectando negocios con la infraestructura móvil más robusta de
            México.
          </p>
        </div>

        <!-- Social Icons (Bottom alignment) -->
        <div class="flex items-center gap-2 mt-8 lg:mt-0">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                class="group flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-500 transition-all hover:border-blue-500 hover:text-blue-600 hover:shadow-md dark:border-slate-800 dark:bg-slate-900 dark:text-slate-400 dark:hover:border-blue-500 dark:hover:text-blue-400"
                aria-label={social.name}
              >
                <SocialIcon name={social.name} size="sm" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- LINKS NAV (5 cols) -->
      <div class="lg:col-span-5 grid grid-cols-2 sm:grid-cols-3 gap-8">
        {
          footerLinks.map((section) => (
            <div>
              <h3 class="font-bold text-xs uppercase tracking-widest text-slate-900 dark:text-white mb-6">
                {section.title}
              </h3>
              <ul class="space-y-3">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="group flex items-center gap-2 text-sm text-slate-500 transition-colors hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400"
                    >
                      <span class="h-px w-0 bg-blue-600 transition-all group-hover:w-2 dark:bg-blue-400" />
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- CERTIFICATIONS & CONTACT (3 cols) -->
      <div class="lg:col-span-3 space-y-8">
        <!-- Contact Block -->
        <div>
          <h3
            class="font-bold text-xs uppercase tracking-widest text-slate-900 dark:text-white mb-6"
          >
            Atención a Clientes
          </h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div
                class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400"
              >
                <svg
                  class="h-3 w-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-xs text-slate-500 dark:text-slate-400">
                  Lunes a Sábado, 9am - 7pm
                </p>
                <a
                  href="tel:9616189200"
                  class="text-sm font-semibold text-slate-900 hover:text-blue-600 dark:text-white dark:hover:text-blue-400"
                  >961 618 92 00</a
                >
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div
                class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400"
              >
                <svg
                  class="h-3 w-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path></svg
                >
              </div>
              <a
                href="mailto:soporte@linea-digital.com"
                class="text-sm font-semibold text-slate-900 hover:text-blue-600 dark:text-white dark:hover:text-blue-400 mt-0.5"
                >soporte@linea-digital.com</a
              >
            </li>
          </ul>
        </div>

        <!-- Trust Badges -->
        <div
          class="rounded-2xl border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900"
        >
          <p class="mb-3 text-[10px] font-bold uppercase text-slate-400">
            Pagos Seguros & Certificaciones
          </p>
          <div
            class="flex flex-wrap items-center gap-3 opacity-60 grayscale transition-all hover:opacity-100 hover:grayscale-0"
          >
            <!-- SVGs Inline para logos de tarjetas/certificaciones -->
            <svg
              class="h-6 w-auto"
              viewBox="0 0 38 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M35 0H3C1.3 0 0 1.3 0 3V21C0 22.7 1.3 24 3 24H35C36.7 24 38 22.7 38 21V3C38 1.3 36.7 0 35 0Z"
                fill="#2566AF"></path><path
                d="M35 1H3C1.9 1 1 1.9 1 3V21C1 22.1 1.9 23 3 23H35C36.1 23 37 22.1 37 21V3C37 1.9 36.1 1 35 1Z"
                fill="#1A1F71"></path><path
                d="M13.2 11.4H15.6L14.1 18.4H11.8L11.3 12.8C11.3 12.6 11.2 12.5 11.1 12.4C10.6 11.9 9.3 11.3 8.1 11.2L12.5 21.3H14.9L19.2 11.4H16.8L13.2 11.4ZM23.8 11.4H21.4C21.1 11.4 20.8 11.5 20.7 11.8L17.7 18.4L19.5 18.4L19.9 17.5H22.4L22.6 18.4H24.3L23.8 11.4ZM20.4 16.5L21 14.7L21.6 16.5H20.4ZM27.2 11.4H25.3L23.4 18.4H25.6L25.9 17.2C26.7 17.2 27.6 17.1 28.3 16.5C28.9 16.1 29.1 15.5 29.1 14.8C29.2 12.7 27.2 11.4 27.2 11.4ZM26.2 15.6C26 15.7 25.8 15.8 25.6 15.8L26 13.9C26.5 13.9 26.9 14.1 26.9 14.8C26.9 15.2 26.6 15.5 26.2 15.6ZM9.5 11.4H6.5L6.3 10.4C8.4 10.4 10.6 10.8 12.4 11.9L11.8 14.7L9.5 11.4Z"
                fill="white"></path></svg
            >
            <svg
              class="h-6 w-auto"
              viewBox="0 0 38 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><rect width="38" height="24" rx="3" fill="#222"></rect><path
                d="M22.5 12C22.5 8.7 24.3 5.8 26.9 4.2C24.5 2.5 21.6 1.5 18.5 1.5C11.2 1.5 5.2 7.2 4.9 14.4C4.8 14.5 4.8 14.7 4.8 14.9C4.8 15.2 4.8 15.5 4.9 15.8C5.8 20.2 9.6 23.5 14.3 23.5C18.1 23.5 21.5 21.6 23.6 18.6C22.9 18.8 22.2 18.9 21.5 18.9C16.9 18.9 12.9 16.2 11.1 12.3C12.7 14.6 15.4 16.1 18.5 16.1C22.2 16.1 25.4 13.7 26.5 10.3C27.2 12.3 27.6 14.4 27.6 16.6C27.6 19.3 26.9 21.9 25.6 24.1C29.5 23.3 32.7 20.6 34.3 17C35.5 14.3 35.8 11.2 35.2 8.3C33.8 10.6 31.3 12 28.5 12C25.7 12 23.2 10.6 21.8 8.3C21.2 11.2 21.5 14.3 22.7 17C24.3 20.6 27.5 23.3 31.4 24.1C30.1 21.9 29.4 19.3 29.4 16.6C29.4 14.4 29.8 12.3 30.5 10.3C31.6 13.7 34.8 16.1 38.5 16.1C41.6 16.1 44.3 14.6 45.9 12.3C44.1 16.2 40.1 18.9 35.5 18.9C34.8 18.9 34.1 18.8 33.4 18.6C35.5 21.6 38.9 23.5 42.7 23.5C47.4 23.5 51.2 20.2 52.1 15.8C52.2 15.5 52.2 15.2 52.2 14.9C52.2 14.7 52.2 14.5 52.1 14.4C51.8 7.2 45.8 1.5 38.5 1.5C35.4 1.5 32.5 2.5 30.1 4.2C32.7 5.8 34.5 8.7 34.5 12H22.5Z"
                fill="#FF5F00"></path><path
                d="M14.3 23.5C9.6 23.5 5.8 20.2 4.9 15.8C4.8 15.5 4.8 15.2 4.8 14.9C4.8 14.7 4.8 14.5 4.9 14.4C5.2 7.2 11.2 1.5 18.5 1.5C21.6 1.5 24.5 2.5 26.9 4.2C24.3 5.8 22.5 8.7 22.5 12C22.5 15.3 24.3 18.2 26.9 19.8C24.5 21.5 21.6 22.5 18.5 22.5C18.5 22.5 18.5 22.5 18.5 22.5C18.4 22.5 18.4 22.5 18.3 22.5C16.9 22.5 15.6 22.2 14.3 21.7V23.5Z"
                fill="#EB001B"></path><path
                d="M38.5 1.5C35.4 1.5 32.5 2.5 30.1 4.2C32.7 5.8 34.5 8.7 34.5 12C34.5 15.3 32.7 18.2 30.1 19.8C32.5 21.5 35.4 22.5 38.5 22.5C45.8 22.5 51.8 16.8 52.1 9.6C52.2 9.4 52.2 9.2 52.2 8.9C52.2 8.6 52.2 8.3 52.1 8.0C51.2 3.6 47.4 0.3 42.7 0.3H38.5V1.5Z"
                fill="#F79E1B"></path></svg
            >
            <div class="h-6 w-px bg-slate-300 dark:bg-slate-700"></div>
            <!-- SSL Icon -->
            <svg
              class="h-5 w-auto text-slate-400"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
              ></path></svg
            >
          </div>
        </div>
      </div>
    </div>

    <!-- 3. BOTTOM BAR (Legal & Compliance) -->
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-6 text-xs"
    >
      <div
        class="flex flex-col md:flex-row items-center gap-2 md:gap-6 text-slate-500 dark:text-slate-500"
      >
        <p>
          © {currentYear}
          <span class="font-bold text-slate-700 dark:text-slate-300"
            >Grupo Línea Digital</span
          >.
        </p>
        <span class="hidden md:block text-slate-300 dark:text-slate-700">|</span
        >
        <p>Distribuidor Autorizado Telcel R9.</p>
      </div>

      <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-2">
        <a
          href="/legal/privacidad"
          class="text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400 transition-colors"
          >Aviso de Privacidad</a
        >
        <a
          href="/legal/terminos"
          class="text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400 transition-colors"
          >Términos y Condiciones</a
        >
        <a
          href="/sitemap"
          class="text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400 transition-colors"
          >Mapa del Sitio</a
        >
      </div>
    </div>
  </div>
</footer>
