---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import gridManImage from "../assets/grid-man-image-compress.webp"; // Asegúrate de tener esta imagen
import "../styles/user.css";
import Testimonials from "../components/Testimonials.astro";

// --- DATA: Marcas que distribuyes (Ticker) ---
const BRANDS = [
  { name: "Telcel", opacity: "opacity-100" },
  { name: "Apple", opacity: "opacity-70" },
  { name: "Samsung", opacity: "opacity-70" },
  { name: "Motorola", opacity: "opacity-70" },
  { name: "Xiaomi", opacity: "opacity-70" },
  { name: "Oppo", opacity: "opacity-70" },
];

// --- DATA: Servicios (Bento Grid) ---
const SERVICES = [
  {
    title: "Corporativo & PyME",
    desc: "Planes de renta masivos y gestión de flotillas.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    color: "bg-blue-500",
  },
  {
    title: "Distribución Mayorista",
    desc: "Precios especiales por volumen para asociados.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
    color: "bg-indigo-500",
  },
  {
    title: "Internet of Things (IoT)",
    desc: "Conectividad para GPS, sensores y telemetría.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>`,
    color: "bg-cyan-500",
  },
];
---

<BaseLayout
  title="Grupo Linea Digital | Infraestructura Telcel para Empresas"
  description="Distribuidor Autorizado Telcel especializado en soluciones B2B, flotillas y distribución mayorista en el sureste de México."
>
  <!-- BACKGROUND GLOBAL: "Technical Noise" -->
  <div
    class="fixed inset-0 z-0 pointer-events-none opacity-[0.04] mix-blend-overlay"
  >
    <svg width="100%" height="100%">
      <filter id="noise">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.85"
          numOctaves="4"
          stitchTiles="stitch"></feTurbulence>
      </filter>
      <rect width="100%" height="100%" filter="url(#noise)"></rect>
    </svg>
  </div>

  <!-- === HERO SECTION === -->
  <section
    class="relative w-full pt-32 pb-16 md:pt-48 md:pb-24 overflow-hidden transition-colors duration-500"
  >
    <!-- Hero Background Effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Grid Line Pattern -->
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
      >
      </div>
      <!-- Glow Top -->
      <div
        class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-blue-600/20 blur-[100px] rounded-full mix-blend-normal dark:mix-blend-screen"
      >
      </div>
    </div>

    <div
      class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center"
    >
      <!-- Status Badge -->
      <div class="animate-fade-up flex justify-center mb-8">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-white/60 px-3 py-1 text-xs font-bold uppercase tracking-widest text-blue-700 shadow-sm backdrop-blur-md dark:border-blue-800/50 dark:bg-blue-950/30 dark:text-blue-400"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-75"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-blue-500"
            ></span>
          </span>
          Red 5G Ready
        </div>
      </div>

      <!-- Main Heading -->
      <h1
        class="mx-auto max-w-5xl text-5xl font-black tracking-tight text-slate-900 dark:text-white sm:text-6xl md:text-7xl lg:text-8xl lg:leading-[0.95] mb-8 animate-fade-up animation-delay-100"
      >
        Infraestructura móvil para <br class="hidden md:block" />
        <span
          class="relative whitespace-nowrap text-transparent bg-clip-text bg-gradient-to-r from-blue-700 via-blue-600 to-cyan-500 dark:from-blue-400 dark:via-blue-300 dark:to-cyan-300"
        >
          empresas exigentes.
          <svg
            aria-hidden="true"
            viewBox="0 0 418 42"
            class="absolute left-0 top-2/3 h-[0.58em] w-full fill-blue-300/20 dark:fill-blue-700/20 -z-10"
            preserveAspectRatio="none"
            ><path
              d="M203.371.916c-26.013-2.078-76.686 1.963-124.73 9.946L67.3 12.749C61.321 13.65 13.889 23.151 1 23.949c-12.871.798 12.871 3.592 12.871 3.592 0 0 17.595-3.592 20.916-4.39 3.32-.798 52.827-9.578 57.218-9.977 4.39-.399 224.234-9.977 224.234-9.977 0 0 83.277 1.995 89.172 2.793 5.895.798-8.157-5.587-8.157-5.587s-20.354-2.793-68.847-5.986c-48.493-3.193-113.664-5.188-124.73-3.991Z"
            ></path></svg
          >
        </span>
      </h1>

      <p
        class="mx-auto mb-10 max-w-2xl text-lg md:text-xl font-medium leading-relaxed text-slate-600 dark:text-slate-400 animate-fade-up animation-delay-200"
      >
        Somos el puente entre tu negocio y la red de Telcel. Hardware de
        vanguardia, planes corporativos y distribución mayorista en un solo
        lugar.
      </p>

      <!-- Action Buttons -->
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-up animation-delay-300"
      >
        <a
          href="/empresas"
          class="group relative inline-flex h-14 w-full sm:w-auto items-center justify-center overflow-hidden rounded-full bg-slate-900 px-8 font-bold text-white shadow-xl shadow-slate-900/20 transition-all hover:scale-105 hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-blue-50"
        >
          <span class="mr-2">Cotizar Soluciones</span>
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
        <a
          href="/asociados"
          class="inline-flex h-14 w-full sm:w-auto items-center justify-center rounded-full border border-slate-200 bg-white px-8 font-bold text-slate-700 transition-all hover:border-slate-300 hover:bg-slate-50 dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
        >
          Quiero ser Distribuidor
        </a>
      </div>

      <!-- BRANDS TICKER (TRUST) -->
      <div
        class="mt-20 border-t border-slate-200/60 pt-10 dark:border-white/5 animate-fade-up animation-delay-300"
      >
        <p
          class="mb-6 text-xs font-bold uppercase tracking-widest text-slate-400"
        >
          Distribuidor Autorizado de Tecnología
        </p>
        <div
          class="flex flex-wrap justify-center items-center gap-x-8 gap-y-6 grayscale opacity-80 mix-blend-multiply dark:mix-blend-normal dark:opacity-60"
        >
          <!-- Placeholder Logos (Text for cleanliness, replace with SVGs ideally) -->
          {
            BRANDS.map((brand) => (
              <span
                class={`text-xl font-black text-slate-400 dark:text-slate-500 ${brand.opacity}`}
              >
                {brand.name}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- === FEATURE SPLIT: "ECOSISTEMA" === -->
  <section
    class="py-24 px-6 relative z-10 border-t border-slate-100 dark:border-white/5"
  >
    <div class="mx-auto max-w-7xl">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center"
      >
        <!-- Left: Visual "Dashboard" Look -->
        <div class="relative order-2 lg:order-1 group">
          <!-- Glow back -->
          <div
            class="absolute -inset-4 bg-gradient-to-r from-blue-500/20 to-purple-500/20 blur-2xl opacity-50 rounded-[2.5rem] group-hover:opacity-75 transition-opacity duration-500"
          >
          </div>

          <!-- Main Image Container -->
          <div
            class="relative rounded-[2rem] overflow-hidden border border-slate-200 dark:border-white/10 shadow-2xl bg-slate-900"
          >
            <Image
              src={gridManImage}
              alt="Dashboard de Control"
              class="w-full h-auto object-cover opacity-90 group-hover:scale-105 transition-transform duration-700 ease-out"
            />

            <!-- Floating Elements (Glassmorphism) -->
            <div class="absolute bottom-6 left-6 right-6">
              <div class="flex flex-col gap-3">
                <!-- Card 1 -->
                <div
                  class="flex items-center gap-4 rounded-xl bg-white/10 backdrop-blur-md border border-white/20 p-4 text-white shadow-lg animate-fade-up"
                >
                  <div
                    class="h-10 w-10 rounded-lg bg-green-500 flex items-center justify-center shrink-0"
                  >
                    <svg
                      class="h-6 w-6"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      ></path></svg
                    >
                  </div>
                  <div>
                    <p class="text-xs font-bold uppercase opacity-80">
                      Rendimiento de Red
                    </p>
                    <p class="text-lg font-bold">Óptimo (99.9%)</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Content -->
        <div class="relative order-1 lg:order-2">
          <div
            class="inline-flex items-center gap-2 mb-6 rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-widest text-slate-600 dark:bg-white/10 dark:text-slate-300"
          >
            <span class="h-2 w-2 rounded-full bg-blue-600"></span>
            Ecosistema Integral
          </div>

          <h2
            class="text-3xl md:text-5xl font-black tracking-tight text-slate-900 dark:text-white mb-6"
          >
            Todo lo que tu negocio necesita para <span
              class="text-blue-600 dark:text-blue-500">escalar.</span
            >
          </h2>

          <p
            class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed"
          >
            Centralizamos la tecnología. Ya no necesitas múltiples proveedores
            para equipar a tu equipo de ventas, gerencia o soporte.
          </p>

          <!-- Interactive List -->
          <div class="space-y-6">
            {
              SERVICES.map((service) => (
                <div class="group flex gap-4 p-4 rounded-2xl transition-all hover:bg-slate-50 dark:hover:bg-white/5 border border-transparent hover:border-slate-200 dark:hover:border-white/10">
                  <div
                    class={`h-12 w-12 rounded-xl ${service.color} bg-opacity-10 text-${service.color.replace("bg-", "")} flex items-center justify-center shrink-0`}
                  >
                    <div
                      class={`h-12 w-12 rounded-xl flex items-center justify-center text-white ${service.color} shadow-lg shadow-${service.color.replace("bg-", "")}/30`}
                    >
                      <Fragment set:html={service.icon} />
                    </div>
                  </div>
                  <div>
                    <h3 class="font-bold text-slate-900 dark:text-white text-lg">
                      {service.title}
                    </h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                      {service.desc}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- === LOCATIONS DASHBOARD === -->
  <!-- 3. LOCATIONS SECTION (Interactive Dashboard Style) -->
  <section class="py-24 px-6 bg-white dark:bg-slate-950 transition-colors">
    <div class="container mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Left: Control Panel -->
        <div class="lg:col-span-5 flex flex-col justify-center">
          <span
            class="text-blue-600 dark:text-blue-400 font-bold uppercase tracking-widest text-xs mb-2"
            >Presencia Física</span
          >
          <h2
            class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-8"
          >
            Centros de Atención <br /> Corporativa
          </h2>

          <div class="space-y-4">
            <!-- Card Tuxtla -->
            <button
              onclick="showMap('tuxtla')"
              id="btn-tuxtla"
              class="location-card w-full text-left p-6 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-blue-400 dark:hover:border-blue-600 transition-all duration-300 group data-[active=true]:bg-blue-50 dark:data-[active=true]:bg-blue-900/10 data-[active=true]:border-blue-500 data-[active=true]:ring-1 data-[active=true]:ring-blue-500"
              data-active="true"
            >
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-bold text-lg text-slate-900 dark:text-white">
                  Tuxtla Gutiérrez
                </h3>
                <span
                  class="h-2 w-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"
                ></span>
              </div>
              <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
                Sede Central y Almacén General.
              </p>
              <div
                class="flex items-center gap-2 text-xs font-medium text-slate-400 group-hover:text-blue-600 transition-colors"
              >
                <span>Ver en mapa</span>
                <svg
                  class="w-3 h-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path></svg
                >
              </div>
            </button>

            <!-- Card Tapachula -->
            <button
              onclick="showMap('tapachula')"
              id="btn-tapachula"
              class="location-card w-full text-left p-6 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-blue-400 dark:hover:border-blue-600 transition-all duration-300 group data-[active=true]:bg-blue-50 dark:data-[active=true]:bg-blue-900/10 data-[active=true]:border-blue-500 data-[active=true]:ring-1 data-[active=true]:ring-blue-500"
              data-active="false"
            >
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-bold text-lg text-slate-900 dark:text-white">
                  Tapachula
                </h3>
                <span
                  class="h-2 w-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"
                ></span>
              </div>
              <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
                Centro Logístico Frontera Sur.
              </p>
              <div
                class="flex items-center gap-2 text-xs font-medium text-slate-400 group-hover:text-blue-600 transition-colors"
              >
                <span>Ver en mapa</span>
                <svg
                  class="w-3 h-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path></svg
                >
              </div>
            </button>
          </div>
        </div>

        <!-- Right: Map Viewport -->
        <div class="lg:col-span-7 h-[400px] lg:h-auto min-h-[500px] relative">
          <!-- Frame Estético -->
          <div
            class="absolute inset-0 rounded-[2.5rem] bg-slate-100 dark:bg-slate-800 border-[8px] border-slate-100 dark:border-slate-800 shadow-2xl overflow-hidden ring-1 ring-slate-200 dark:ring-slate-700"
          >
            <!-- Mapas superpuestos -->
            <div class="relative w-full h-full bg-slate-200 dark:bg-slate-900">
              <!-- Tuxtla -->
              <iframe
                id="map-tuxtla"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3820.4196777143943!2d-93.1224185!3d16.7557832!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ecd8f3d3af5e09%3A0xedacab470275254a!2sLinea%20Digital%20del%20Sureste!5e0!3m2!1ses-419!2smx!4v1741478607844"
                class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700 opacity-100 grayscale-[0.5] hover:grayscale-0"
                loading="lazy"
                title="Mapa Tuxtla"></iframe>

              <!-- Tapachula -->
              <iframe
                id="map-tapachula"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3855.4472567510143!2d-92.2621971!3d14.912154999999998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x858e0ed8913f73ad%3A0xab0ea708b27df293!2sL%C3%ADnea%20Digital%20del%20Sureste%20Tapachula!5e0!3m2!1sen!2smx!4v1763676826030"
                class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700 opacity-0 pointer-events-none grayscale-[0.5] hover:grayscale-0"
                loading="lazy"
                title="Mapa Tapachula"></iframe>

              <!-- Overlay de carga / textura -->
              <div
                class="absolute inset-0 pointer-events-none border-[1px] border-black/5 rounded-[2rem] shadow-inner"
              >
              </div>
            </div>

            <!-- Floating Info Card (Sobre el mapa) -->
            <div
              class="absolute bottom-6 left-6 right-6 p-4 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-xl border border-white/20 shadow-lg flex justify-between items-center z-10"
            >
              <div>
                <p
                  class="text-[10px] font-bold uppercase tracking-widest text-slate-400"
                >
                  Horario de Atención
                </p>
                <p class="text-sm font-bold text-slate-900 dark:text-white">
                  Lun - Sáb: 9:00 AM - 7:00 PM
                </p>
              </div>
              <a
                href="https://wa.me/529616189200"
                target="_blank"
                class="h-10 w-10 rounded-full bg-blue-600 text-white flex items-center justify-center hover:bg-blue-500 transition-colors shadow-lg shadow-blue-600/20"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                  ></path></svg
                >
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- === TESTIMONIOS === -->
  <Testimonials />
</BaseLayout>

<script is:inline>
  // Usamos is:inline para asegurar que se ejecute inmediatamente en el cliente
  // y definimos las funciones en el scope global (window)

  function showMap(location) {
    // 1. Map Switching Logic
    const tuxtlaMap = document.getElementById("map-tuxtla");
    const tapachulaMap = document.getElementById("map-tapachula");

    if (!tuxtlaMap || !tapachulaMap) return;

    if (location === "tuxtla") {
      tuxtlaMap.style.opacity = "1";
      tuxtlaMap.style.pointerEvents = "auto";
      tapachulaMap.style.opacity = "0";
      tapachulaMap.style.pointerEvents = "none";
    } else {
      tapachulaMap.style.opacity = "1";
      tapachulaMap.style.pointerEvents = "auto";
      tuxtlaMap.style.opacity = "0";
      tuxtlaMap.style.pointerEvents = "none";
    }

    // 2. Button State Logic
    const buttons = document.querySelectorAll(".location-card");
    buttons.forEach((btn) => {
      if (btn.id === `btn-${location}`) {
        btn.setAttribute("data-active", "true");
      } else {
        btn.setAttribute("data-active", "false");
      }
    });
  }

  // Expose to window for onclick handlers
  window.showMap = showMap;
</script>

<style>
  /* Custom Animations */
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fade-up 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    opacity: 0;
  }

  .animation-delay-100 {
    animation-delay: 100ms;
  }
  .animation-delay-200 {
    animation-delay: 200ms;
  }
  .animation-delay-300 {
    animation-delay: 300ms;
  }

  /* Map Indicator Transition */
  .location-btn .indicator {
    transform: scaleY(0);
  }
  .location-btn.active-location .indicator {
    transform: scaleY(1);
  }
</style>
