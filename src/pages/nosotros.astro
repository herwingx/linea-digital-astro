---
// src/pages/quienes-somos.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import AnimatedCounter from "../components/AnimatedCounter.astro";
import InteractiveMexicoMap from "../components/InteractiveMexicoMap.astro"; // Asumimos que existe
import "../styles/user.css";

// SVG Constants (Clean Code)
const ICONS = {
    MEXICO: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    ROCKET: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    CHECK: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`
};

const STATS = [
    { value: 2500, label: "Puntos de Venta", col: "md:col-span-1" },
    { value: 120, label: "Socios Comerciales", col: "md:col-span-1" },
    { value: 500000, label: "Clientes Conectados", col: "md:col-span-2", variant: "primary" }, // Tarjeta Grande
];

const VALUES = [
    { title: "Integridad", desc: "Actuamos con transparencia absoluta.", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
    { title: "Innovación", desc: "5G y plataformas digitales primero.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { title: "Unidad", desc: "Crecemos si nuestros socios crecen.", icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" },
    { title: "Pasión", desc: "Obsesionados con el servicio.", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" }
];
---

<BaseLayout
  title="Nuestra Historia | Grupo Linea Digital"
  description="Liderando la conectividad móvil en el sureste de México desde hace más de 25 años."
>
  <!-- Background Noise Global -->
  <div class="fixed inset-0 pointer-events-none opacity-[0.4] z-0 mix-blend-overlay">
      <svg class="w-full h-full"><filter id="noiseFilter"><feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(#noiseFilter)"/></svg>
  </div>

  <!-- HERO SECTION -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="container relative z-10 mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        
        <!-- TEXT CONTENT -->
        <div class="text-center lg:text-left relative z-10">
          
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 dark:bg-slate-800 dark:border-slate-700 mb-8 animate-fade-up">
             <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
             </span>
             <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-300">Sobre Nosotros</span>
          </div>

          <h1 class="text-5xl lg:text-7xl font-black tracking-tighter text-slate-900 dark:text-white mb-6 leading-[0.9] animate-fade-up animation-delay-100">
            Conectando <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">Historias Reales.</span>
          </h1>

          <p class="text-xl text-slate-500 dark:text-slate-400 leading-relaxed mb-10 max-w-lg mx-auto lg:mx-0 animate-fade-up animation-delay-200">
            Más de <strong class="text-slate-900 dark:text-white">25 años</strong> impulsando la comunicación en México. Somos la infraestructura invisible que mantiene unida a tu comunidad.
          </p>

          <div class="flex flex-wrap gap-4 justify-center lg:justify-start animate-fade-up animation-delay-300">
            <div class="flex items-center gap-3 px-6 py-4 rounded-2xl bg-white/50 border border-slate-200 backdrop-blur-sm dark:bg-slate-900/50 dark:border-slate-700 shadow-sm transition-transform hover:scale-105">
               <div class="p-2 rounded-lg bg-blue-50 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400">
                   <Fragment set:html={ICONS.MEXICO} />
               </div>
               <div class="text-left">
                   <p class="text-xs font-bold uppercase text-slate-400 tracking-wider">Origen</p>
                   <p class="text-sm font-bold text-slate-900 dark:text-white">100% Mexicanos</p>
               </div>
            </div>
            
            <div class="flex items-center gap-3 px-6 py-4 rounded-2xl bg-white/50 border border-slate-200 backdrop-blur-sm dark:bg-slate-900/50 dark:border-slate-700 shadow-sm transition-transform hover:scale-105">
                <div class="p-2 rounded-lg bg-indigo-50 text-indigo-600 dark:bg-indigo-900/20 dark:text-indigo-400">
                    <Fragment set:html={ICONS.ROCKET} />
                </div>
                <div class="text-left">
                    <p class="text-xs font-bold uppercase text-slate-400 tracking-wider">Tecnología</p>
                    <p class="text-sm font-bold text-slate-900 dark:text-white">Líderes 5G</p>
                </div>
             </div>
          </div>
        </div>

        <!-- MAP VISUAL (Glassmorphism Container) -->
        <div class="relative perspective-1000 group lg:order-last order-first mb-10 lg:mb-0">
            <!-- Background Glow -->
            <div class="absolute inset-0 bg-gradient-to-tr from-blue-500/20 to-purple-500/20 blur-[60px] rounded-full opacity-60"></div>
            
            <!-- Glass Container -->
            <div class="relative rounded-[2.5rem] bg-white/40 dark:bg-slate-900/40 border border-white/50 dark:border-white/10 backdrop-blur-xl shadow-2xl shadow-blue-900/10 p-4 transition-transform duration-700 group-hover:rotate-y-2 group-hover:scale-[1.01]">
                <div class="relative rounded-[2rem] overflow-hidden bg-slate-50 dark:bg-slate-950 aspect-[4/3] md:aspect-auto">
                     <InteractiveMexicoMap />
                     <!-- Overlay sutil para unificar colores -->
                     <div class="absolute inset-0 bg-blue-900/5 dark:bg-blue-500/5 pointer-events-none mix-blend-overlay"></div>
                </div>

                <!-- Floating Badge -->
                <div class="absolute top-8 right-8 animate-bounce-slow">
                    <div class="px-4 py-2 rounded-xl bg-white dark:bg-slate-800 shadow-lg border border-slate-100 dark:border-slate-700 flex items-center gap-3">
                        <span class="flex h-3 w-3 relative">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                        </span>
                        <span class="text-xs font-bold uppercase tracking-widest text-slate-700 dark:text-slate-200">Cobertura Total</span>
                    </div>
                </div>
            </div>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS BENTO GRID -->
  <section class="py-20 relative">
      <div class="container mx-auto px-6 max-w-7xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <!-- Texto Intro (Ocupa espacio) -->
            <div class="lg:col-span-1 flex flex-col justify-end p-4">
                <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight leading-none mb-4">
                    Impacto <br/> <span class="text-blue-600">Mensurable.</span>
                </h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                    Nuestros números reflejan la confianza que miles de mexicanos depositan en nosotros cada día.
                </p>
            </div>

            <!-- Stats Cards Loop -->
            {STATS.map((stat) => (
                <div class={`
                    group relative flex flex-col justify-between p-8 rounded-[2.5rem] 
                    border transition-all duration-500
                    ${stat.variant === 'primary' 
                        ? 'bg-blue-600 border-blue-500 text-white lg:col-span-2 shadow-xl shadow-blue-600/20' 
                        : 'bg-white dark:bg-slate-900 border-slate-200 dark:border-slate-800 hover:border-blue-300 dark:hover:border-blue-700 lg:col-span-1'}
                `}>
                    <!-- Icon Decorativo -->
                    <div class="absolute top-8 right-8 opacity-10 scale-150 pointer-events-none group-hover:scale-125 transition-transform duration-500">
                        <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"></path></svg>
                    </div>

                    <div class="mt-auto relative z-10">
                        <div class={`text-5xl md:text-6xl font-black tracking-tighter mb-2 ${stat.variant === 'primary' ? 'text-white' : 'text-slate-900 dark:text-white'}`}>
                            <AnimatedCounter end={stat.value} prefix="+" />
                        </div>
                        <p class={`text-xs font-bold uppercase tracking-widest ${stat.variant === 'primary' ? 'text-blue-100' : 'text-slate-500 dark:text-slate-400'}`}>
                            {stat.label}
                        </p>
                    </div>
                </div>
            ))}
        </div>
      </div>
  </section>

  <!-- BRAND GRID (Clean) -->
  <section class="py-20 border-y border-slate-100 dark:border-white/5 bg-slate-50/50 dark:bg-slate-900/50">
      <div class="container mx-auto px-6">
          <p class="text-center text-xs font-bold uppercase tracking-widest text-slate-400 mb-10">Trusted By The Best</p>
          
          <div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-slate-200 dark:bg-white/5 border border-slate-200 dark:border-white/5 rounded-2xl overflow-hidden">
             {["Apple", "Samsung", "Xiaomi", "Motorola", "Huawei", "Oppo", "ZTE", "Honor", "Nokia", "Telcel"].map((brand) => (
                 <div class="bg-white dark:bg-slate-950 p-8 flex items-center justify-center group transition-colors hover:bg-slate-50 dark:hover:bg-slate-900">
                    <span class="text-lg font-bold text-slate-300 group-hover:text-slate-800 dark:text-slate-700 dark:group-hover:text-white transition-colors cursor-default">
                        {brand}
                    </span>
                 </div>
             ))}
          </div>
      </div>
  </section>

  <!-- PHILOSOPHY SECTION (Minimalist Orbit) -->
  <section class="py-32 relative overflow-hidden">
      <!-- Gradient Orb Background -->
      <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-blue-400/5 to-cyan-400/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="container mx-auto px-6 relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
              
              <!-- Left: Abstract Visual -->
              <div class="relative flex justify-center order-2 lg:order-1">
                  <!-- CSS Only Orbit System -->
                  <div class="relative w-[300px] h-[300px] md:w-[500px] md:h-[500px]">
                      <!-- Core -->
                      <div class="absolute inset-0 m-auto w-32 h-32 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-600 shadow-[0_0_60px_rgba(37,99,235,0.4)] flex items-center justify-center z-20">
                          <svg class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                      </div>
                      
                      <!-- Orbit 1 -->
                      <div class="absolute inset-0 m-auto w-[60%] h-[60%] rounded-full border border-slate-200 dark:border-white/5 animate-spin-slow">
                          <div class="absolute -top-2 left-1/2 w-4 h-4 rounded-full bg-blue-400 shadow-[0_0_15px_rgba(96,165,250,0.6)]"></div>
                      </div>

                      <!-- Orbit 2 -->
                      <div class="absolute inset-0 m-auto w-[100%] h-[100%] rounded-full border border-dashed border-slate-200 dark:border-white/10 animate-spin-reverse-slower opacity-60">
                          <div class="absolute top-1/2 -right-3 w-6 h-6 rounded-full bg-white dark:bg-slate-800 border-4 border-slate-100 dark:border-slate-700 shadow-xl"></div>
                      </div>
                  </div>
              </div>

              <!-- Right: Content -->
              <div class="order-1 lg:order-2">
                  <span class="text-blue-600 font-bold uppercase tracking-widest text-xs mb-4 block">Nuestro ADN</span>
                  <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-8 tracking-tight">
                      Valores que construyen <br/>
                      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Confianza.</span>
                  </h2>
                  <p class="text-lg text-slate-500 dark:text-slate-400 mb-12">
                      No se trata solo de vender tecnología, sino de actuar con principios inquebrantables que garanticen relaciones a largo plazo.
                  </p>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                      {VALUES.map((val) => (
                          <div class="group flex items-start gap-4">
                              <div class="w-10 h-10 rounded-full bg-blue-50 dark:bg-white/5 flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform duration-300">
                                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={val.icon}/></svg>
                              </div>
                              <div>
                                  <h3 class="font-bold text-slate-900 dark:text-white">{val.title}</h3>
                                  <p class="text-sm text-slate-500 dark:text-slate-400 leading-snug mt-1">{val.desc}</p>
                              </div>
                          </div>
                      ))}
                  </div>
              </div>

          </div>
      </div>
  </section>

</BaseLayout>

<style>
    .animate-spin-slow {
        animation: spin 20s linear infinite;
    }
    .animate-spin-reverse-slower {
        animation: spin 35s linear infinite reverse;
    }
    
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .animate-bounce-slow {
        animation: bounce 4s infinite;
    }
    
    /* Utilería para View Transitions suave */
    @keyframes fade-up {
       from { opacity: 0; transform: translateY(20px); }
       to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
       animation: fade-up 0.8s ease-out forwards;
       opacity: 0;
    }
    .animation-delay-100 { animation-delay: 100ms; }
    .animation-delay-200 { animation-delay: 200ms; }
    .animation-delay-300 { animation-delay: 300ms; }
</style>