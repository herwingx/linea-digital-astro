---
import BaseLayout from "../layouts/BaseLayout.astro";
import AnimatedCounter from "../components/AnimatedCounter.astro"; // Importamos el contador

// --- TYPES & DATA ---
interface Feature {
  title: string;
  desc: string;
  iconPath: string;
  colSpan: string;
  colorClass: string;
}

const ICONS = {
  PROFIT: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  SHIELD: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  DASHBOARD: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z",
  NETWORK: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
};

const FEATURES: Feature[] = [
  {
    title: "Profit Share Dinámico",
    desc: "Modelo escalonado de ingresos. Supera objetivos y desbloquea hasta un 15% de comisión adicional sobre la base.",
    iconPath: ICONS.PROFIT,
    colSpan: "md:col-span-2", 
    colorClass: "text-blue-500"
  },
  {
    title: "Riesgo Financiero Cero",
    desc: "Olvídate del inventario obsoleto. Operas bajo consignación digital o dropshipping automático.",
    iconPath: ICONS.SHIELD,
    colSpan: "md:col-span-1",
    colorClass: "text-emerald-500"
  },
  {
    title: "Control Tower SaaS",
    desc: "Tu negocio en el bolsillo. Dashboard en tiempo real para control de saldo y ventas.",
    iconPath: ICONS.DASHBOARD,
    colSpan: "md:col-span-1",
    colorClass: "text-purple-500"
  },
  {
    title: "Infraestructura Carrier",
    desc: "Conectividad nativa a la red Telcel 5G. Latencia mínima, máxima conversión transaccional.",
    iconPath: ICONS.NETWORK,
    colSpan: "md:col-span-2",
    colorClass: "text-cyan-500"
  }
];

const PRODUCTS = [
  { category: "Intangibles", title: "Tiempo Aire", metric: "Alta Rotación", image: "https://images.unsplash.com/photo-1616077168079-7e09a677fb2c?q=80&w=2070&auto=format&fit=crop" },
  { category: "Flagships", title: "Smartphones", metric: "Margen: 12%", image: "https://images.unsplash.com/photo-1592899677977-9c10ca63a16d?q=80&w=1894&auto=format&fit=crop" },
  { category: "Ecosistema", title: "IoT & Audio", metric: "Cross-selling", image: "https://images.unsplash.com/photo-1572569028738-411a097746fc?q=80&w=1974&auto=format&fit=crop" }
];
---

<BaseLayout
  title="Portal de Partners | Grupo Linea Digital"
  description="Plataforma de distribución digital B2B de última generación."
>
  
  <!-- BACKGROUND GLOBAL (Coincide con estilo Quiénes Somos) -->
  <div class="fixed inset-0 pointer-events-none opacity-[0.4] z-0 mix-blend-overlay">
      <svg class="w-full h-full"><filter id="noiseFilter"><feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(#noiseFilter)"/></svg>
  </div>
  
  <!-- Light Blobs Ambientales -->
  <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
      <div class="absolute top-[-10%] left-[20%] w-[40vw] h-[40vw] rounded-full bg-blue-500/10 blur-[100px] mix-blend-multiply dark:mix-blend-screen animate-pulse-slow"></div>
  </div>

  <main class="relative z-10 w-full overflow-hidden">
    
    <!-- 1. HERO SECTION -->
    <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-4 text-center">
      
      <!-- Pill Badge -->
      <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-blue-200/50 bg-blue-50/50 backdrop-blur-md mb-8 animate-fade-in-up dark:border-blue-900/30 dark:bg-blue-900/10 cursor-default hover:border-blue-400/50 transition-colors shadow-sm">
        <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-600 dark:bg-blue-400"></span>
        </span>
        <span class="text-xs font-bold uppercase tracking-widest text-blue-700 dark:text-blue-300">Convocatoria Q4 2024</span>
      </div>

      <h1 class="max-w-5xl mx-auto text-5xl sm:text-7xl font-black tracking-tighter text-slate-900 dark:text-white leading-[0.95] mb-8 animate-fade-in-up animation-delay-100">
        Monetiza tu red con <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 dark:from-blue-400 dark:via-indigo-400 dark:to-purple-400 animate-gradient-x">
          Infraestructura Carrier.
        </span>
      </h1>
      
      <p class="max-w-2xl mx-auto text-xl text-slate-600 dark:text-slate-400 font-medium leading-relaxed mb-12 animate-fade-in-up animation-delay-200">
        Proporcionamos el inventario global, la plataforma SaaS y las licencias operativas. Tú pones el punto de venta.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-5 animate-fade-in-up animation-delay-300">
        <a href="https://wa.me/529616189200" target="_blank" class="group relative flex h-14 items-center justify-center gap-3 overflow-hidden rounded-full bg-slate-900 px-8 text-sm font-bold uppercase tracking-widest text-white shadow-2xl transition-all hover:bg-slate-800 hover:scale-[1.02] active:scale-[0.98] dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100">
            <span class="relative z-10">Aplicar Ahora</span>
            <svg class="relative z-10 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            <div class="absolute inset-0 -translate-x-full group-hover:animate-shine bg-gradient-to-r from-transparent via-white/20 to-transparent z-0"></div>
        </a>
        <a href="#modelo" class="h-14 flex items-center justify-center rounded-full border border-slate-200 bg-white/50 backdrop-blur-md px-8 text-sm font-bold uppercase tracking-widest text-slate-600 transition-colors hover:border-slate-300 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white">
            Explorar Modelo
        </a>
      </div>
    </section>

    <!-- 2. STATS HUD (Ahora usando AnimatedCounter) -->
    <!-- Contenedor flotante tipo "Deck" -->
    <div class="container mx-auto px-4 relative z-20 -mt-8 mb-24 animate-fade-in-up animation-delay-300">
        <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-slate-200/50 dark:border-white/10 rounded-[2rem] shadow-2xl shadow-slate-200/50 dark:shadow-black/50 overflow-hidden max-w-5xl mx-auto">
            <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-slate-100 dark:divide-white/5">
                 {/* Item 1 */}
                 <div class="py-8 text-center group cursor-default transition-colors hover:bg-slate-50/50 dark:hover:bg-white/5">
                    <span class="block text-3xl md:text-4xl font-black tracking-tight text-blue-600 dark:text-blue-400 mb-1">
                        <AnimatedCounter end={12400} prefix="+" duration={2000} />
                    </span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Socios Activos</span>
                 </div>
                 
                 {/* Item 2 */}
                 <div class="py-8 text-center group cursor-default transition-colors hover:bg-slate-50/50 dark:hover:bg-white/5">
                    <span class="block text-3xl md:text-4xl font-black tracking-tight text-emerald-500 mb-1">
                         <AnimatedCounter end={99.9} suffix="%" decimals={1} duration={2500} />
                    </span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Uptime Anual</span>
                 </div>

                 {/* Item 3 (Texto Estático) */}
                 <div class="py-8 text-center group cursor-default transition-colors hover:bg-slate-50/50 dark:hover:bg-white/5">
                    <span class="block text-3xl md:text-4xl font-black tracking-tight text-indigo-500 mb-1">Total</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Cobertura Nacional</span>
                 </div>

                 {/* Item 4 */}
                 <div class="py-8 text-center group cursor-default transition-colors hover:bg-slate-50/50 dark:hover:bg-white/5">
                    <span class="block text-3xl md:text-4xl font-black tracking-tight text-purple-500 mb-1">
                        $<AnimatedCounter end={0} decimals={2} duration={1500} />
                    </span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">Costo Inicial</span>
                 </div>
            </div>
        </div>
    </div>

<!-- 3. BENTO GRID SYSTEM -->
    <section id="modelo" class="py-24 px-4 container mx-auto max-w-7xl">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
            <div class="max-w-2xl">
                <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight mb-4">
                    Sistema Operativo <span class="text-slate-400">Comercial.</span>
                </h2>
                <p class="text-lg text-slate-500 dark:text-slate-400">
                    Infraestructura modular diseñada para escalabilidad infinita y cero fricción técnica.
                </p>
            </div>
            <!-- Decorative Line -->
            <div class="hidden md:block flex-1 h-px bg-slate-200 dark:bg-white/10 ml-12 relative top-[-10px]"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-[300px]">
            {FEATURES.map((feat) => (
                <article class={`
                    relative group rounded-[2.5rem] overflow-hidden 
                    bg-white dark:bg-slate-900 
                    border border-slate-200 dark:border-white/5
                    shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 
                    transition-all duration-500 ease-out hover:-translate-y-2
                    ${feat.colSpan}
                `}>
                    
                    <!-- 1. Interactive Background Gradient (Subtle) -->
                    <!-- Se expande y vuelve más vívido en Hover -->
                    <div class={`absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-current opacity-[0.03] group-hover:opacity-10 transition-opacity duration-700 ${feat.colorClass}`}></div>
                    
                    <!-- 2. Decorative Orb (Blurred accent like Promociones) -->
                    <div class={`absolute -top-10 -right-10 w-40 h-40 rounded-full blur-[60px] opacity-20 group-hover:opacity-40 transition-all duration-700 bg-current ${feat.colorClass} group-hover:scale-150`}></div>

                    <!-- 3. Content Layout (Flex Column) -->
                    <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-10 select-none">
                        
                        <!-- Top: Icon Badge (Floating Style) -->
                        <div class="flex items-start justify-between">
                            <div class={`
                                w-14 h-14 rounded-2xl 
                                bg-slate-50 dark:bg-slate-800/80 backdrop-blur-md
                                border border-slate-100 dark:border-white/10
                                flex items-center justify-center
                                shadow-sm group-hover:shadow-md group-hover:scale-110 group-hover:-rotate-3 
                                transition-all duration-500 ease-out
                                ${feat.colorClass}
                            `}>
                                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={feat.iconPath}/></svg>
                            </div>
                        </div>

                        <!-- Bottom: Info & Animations (Matching Promociones Card Logic) -->
                        <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500 ease-out">
                            
                            <!-- Title -->
                            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2 leading-tight">
                                {feat.title}
                            </h3>
                            
                            <!-- Divider Animado (Signature Element) -->
                            <!-- Crece de w-12 a w-full, usando el color de la feature -->
                            <div class={`h-1 rounded-full mt-3 mb-4 transition-all duration-700 ease-out w-12 group-hover:w-full bg-current opacity-30 group-hover:opacity-100 ${feat.colorClass}`}></div>

                            <!-- Description (Reveal effect) -->
                            <p class="text-slate-500 dark:text-slate-400 text-sm font-medium leading-relaxed opacity-80 group-hover:opacity-100 transition-opacity duration-500">
                                {feat.desc}
                            </p>
                            
                            <!-- CTA Reveal (Optional extra detail) -->
                            <div class={`mt-4 flex items-center gap-2 text-xs font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-2 group-hover:translate-y-0 delay-100 ${feat.colorClass}`}>
                                <span>Ver características</span>
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </section>

    <!-- 4. PRODUCTOS (Cinematic Slider) -->
    <section class="py-24 overflow-hidden border-y border-slate-200/50 dark:border-white/5 bg-slate-50/50 dark:bg-slate-900/50 backdrop-blur-sm">
        <div class="container mx-auto px-6 mb-12 flex items-center justify-between">
            <div>
                <span class="text-blue-600 dark:text-blue-400 font-bold uppercase tracking-widest text-xs">Catálogo Q4</span>
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mt-2">Inventario Premium.</h2>
            </div>
            
            <!-- Hint visual de scroll -->
            <div class="hidden md:flex gap-2 text-slate-400">
                <span class="text-xs font-bold uppercase tracking-widest">Desliza</span>
                <svg class="w-4 h-4 animate-bounce-x" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
        </div>

        <!-- Snap Container -->
        <div class="flex gap-6 overflow-x-auto pb-16 px-6 md:px-[max(2rem,calc((100vw-1280px)/2))] snap-x snap-mandatory hide-scrollbar">
            {PRODUCTS.map((prod) => (
                <div class="group relative flex-shrink-0 w-[85vw] md:w-[400px] aspect-[3/4] rounded-[2.5rem] overflow-hidden snap-center cursor-pointer shadow-lg transition-all duration-700 hover:shadow-2xl hover:shadow-blue-900/20 hover:-translate-y-3">
                    <!-- Image -->
                    <img src={prod.image} alt={prod.title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 ease-out group-hover:scale-110" loading="lazy" />
                    
                    <!-- Gradient Overlays -->
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
                    <div class="absolute inset-0 bg-blue-900/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 mix-blend-overlay"></div>

                    <!-- Content -->
                    <div class="absolute bottom-0 left-0 w-full p-8 md:p-10 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                         <div class="mb-4 inline-flex px-3 py-1 rounded-full bg-white/10 border border-white/20 backdrop-blur-md text-[10px] font-bold uppercase tracking-widest text-white shadow-lg">
                            {prod.category}
                         </div>
                         
                         <h3 class="text-3xl font-black text-white mb-2 leading-none drop-shadow-lg">{prod.title}</h3>
                         
                         <!-- Divider Animado -->
                         <div class="h-0.5 bg-gradient-to-r from-blue-500 to-transparent w-12 group-hover:w-full transition-all duration-700 my-4"></div>

                         <div class="flex items-center justify-between opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                             <span class="text-sm font-bold text-blue-100">{prod.metric}</span>
                             <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white hover:bg-white hover:text-blue-900 transition-colors">
                                 <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                             </div>
                         </div>
                    </div>
                </div>
            ))}

            <!-- Card: More (Glassmorphism Style) -->
            <div class="group relative flex-shrink-0 w-[85vw] md:w-[400px] aspect-[3/4] rounded-[2.5rem] snap-center bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 flex flex-col items-center justify-center text-center hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all duration-300">
                 <div class="w-24 h-24 rounded-full bg-slate-200 dark:bg-white/10 flex items-center justify-center text-slate-400 group-hover:text-blue-600 group-hover:scale-110 transition-all duration-500 mb-6">
                    <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                 </div>
                 <span class="font-bold text-xl text-slate-900 dark:text-white group-hover:text-blue-600">Ver Catálogo <br/>Completo</span>
            </div>
        </div>
    </section>

    <!-- 5. FINAL CTA (Efecto Black Hole / Core) -->
    <section class="py-24 px-4 container mx-auto relative overflow-hidden">
         <div class="relative rounded-[3rem] overflow-hidden bg-slate-900 p-12 md:p-24 text-center shadow-2xl shadow-blue-900/40 border border-slate-800 dark:border-white/10 group">
             
             <!-- Animated Backgrounds -->
             <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
             <!-- Orb Core -->
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-tr from-blue-600/40 to-cyan-500/40 rounded-full blur-[100px] animate-pulse-slow"></div>

             <div class="relative z-10 max-w-3xl mx-auto">
                 <h2 class="text-4xl md:text-7xl font-black text-white tracking-tighter mb-8 leading-none">
                     Listo para <br/> facturar?
                 </h2>
                 <p class="text-xl text-slate-300 mb-10 max-w-xl mx-auto font-medium leading-relaxed">
                     El alta es inmediata. Sin burocracia. Únete a la red digital más grande de la región.
                 </p>
                 
                 <a href="https://wa.me/529616189200" class="inline-flex items-center gap-3 px-10 py-5 rounded-full bg-white text-slate-900 font-black tracking-widest uppercase hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] transition-all duration-300">
                     <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.548 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
                     <span>Alta por WhatsApp</span>
                 </a>
             </div>
         </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* === UTILITIES === */
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* Animation: Shine Effect on Button */
  @keyframes shine {
      100% { left: 125%; }
  }
  .animate-shine {
      animation: shine 1.5s;
  }
  
  /* Animación Gradient Text */
  @keyframes gradient-x {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
  }
  .animate-gradient-x {
      background-size: 200% 200%;
      animation: gradient-x 4s ease infinite;
  }
  
  @keyframes pulse-slow {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
      50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.7; }
  }
  .animate-pulse-slow {
      animation: pulse-slow 6s ease-in-out infinite;
  }
  
  @keyframes bounce-x {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(25%); }
  }
  .animate-bounce-x {
      animation: bounce-x 1s infinite;
  }

  /* Fade Up Utility */
  @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
      animation: fade-in-up 0.8s ease-out forwards;
      opacity: 0;
  }
  .animation-delay-100 { animation-delay: 0.1s; }
  .animation-delay-200 { animation-delay: 0.2s; }
  .animation-delay-300 { animation-delay: 0.3s; }
</style>