---
import BaseLayout from "../layouts/BaseLayout.astro";

// Rutas de escape inteligentes
const shortcuts = [
  {
    title: "Planes Empresariales",
    desc: "Soluciones de conectividad",
    href: "/empresas",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
  },
  {
    title: "Soporte Técnico",
    desc: "Hablar con un experto",
    href: "/contacto",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    title: "Volver al Inicio",
    desc: "Reiniciar la navegación",
    href: "/",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  },
];
---

<BaseLayout
  title="404: Señal Perdida | Línea Digital"
  description="No pudimos encontrar la página que buscas. Reestablece la conexión aquí."
>
  <main
    class="relative w-full h-screen min-h-[800px] flex flex-col items-center justify-center overflow-hidden bg-slate-50 dark:bg-[#020617] px-6"
  >
    <!-- BACKGROUND: STATIC NOISE + RADIAL GLOW -->
    <div class="absolute inset-0 pointer-events-none">
      <!-- Ruido -->
      <div
        class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.03] mix-blend-overlay"
      >
      </div>
      <!-- Luz ambiental -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] bg-blue-600/5 blur-[120px] rounded-full dark:bg-blue-600/10"
      >
      </div>
    </div>

    <!-- CONTENT WRAPPER -->
    <div
      class="relative z-10 w-full max-w-4xl mx-auto flex flex-col items-center text-center"
    >
      <!-- 1. STATUS BADGE -->
      <div class="mb-8 animate-fade-in-down">
        <div
          class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-red-200 bg-red-50/50 backdrop-blur-md dark:border-red-900/30 dark:bg-red-900/10 shadow-sm"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"
            ></span>
          </span>
          <span
            class="text-xs font-bold uppercase tracking-widest text-red-600 dark:text-red-400"
          >
            Error de Conexión
          </span>
        </div>
      </div>

      <!-- 2. THE BIG 404 (RADAR STYLE) -->
      <div
        class="relative flex items-center justify-center gap-2 sm:gap-6 font-black text-[120px] sm:text-[180px] leading-none text-slate-200 dark:text-slate-800 select-none animate-fade-in mb-8"
      >
        <!-- Cuatro Izquierdo -->
        <span class="translate-y-2">4</span>

        <!-- EL CERO: Radar Animado -->
        <div
          class="relative w-[120px] h-[120px] sm:w-[160px] sm:h-[160px] flex items-center justify-center"
        >
          <!-- Ondas de Sonar -->
          <div
            class="absolute inset-0 border-2 border-blue-500/20 rounded-full animate-[ping_3s_cubic-bezier(0,0,0.2,1)_infinite]"
          >
          </div>
          <div
            class="absolute inset-0 border-2 border-blue-500/20 rounded-full animate-[ping_3s_cubic-bezier(0,0,0.2,1)_infinite_1s]"
          >
          </div>

          <!-- Círculo Central -->
          <div
            class="relative w-full h-full rounded-full bg-slate-100 dark:bg-[#0f172a] border-4 border-slate-200 dark:border-slate-800 shadow-inner flex items-center justify-center overflow-hidden group"
          >
            <!-- Haz de luz giratorio (Scanner) -->
            <div
              class="absolute inset-0 bg-gradient-to-tr from-transparent via-blue-500/10 to-transparent rounded-full animate-spin-slow"
            >
            </div>

            <!-- Icono de "Desconectado" -->
            <svg
              class="w-12 h-12 sm:w-16 sm:h-16 text-slate-400 dark:text-slate-600 group-hover:text-blue-500 transition-colors duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"
              ></path>
            </svg>
          </div>
        </div>

        <!-- Cuatro Derecho -->
        <span class="translate-y-2">4</span>
      </div>

      <!-- 3. MENSAJE -->
      <div class="max-w-xl space-y-6 mb-16 animate-fade-in-up">
        <h2
          class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white tracking-tight"
        >
          Señal Interrumpida
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          La frecuencia que buscas no está disponible o ha sido movida a otro
          sector de la red. Restablezcamos el enlace.
        </p>
      </div>

      <!-- 4. SHORTCUTS GRID (Escape Routes) -->
      <div
        class="w-full grid grid-cols-1 md:grid-cols-3 gap-4 animate-fade-in-up animation-delay-200"
      >
        {
          shortcuts.map((item) => (
            <a
              href={item.href}
              class="group relative flex flex-col items-center sm:items-start text-center sm:text-left p-6 rounded-[1.5rem] bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/5 hover:border-blue-300 dark:hover:border-blue-500/50 shadow-sm hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="mb-4 p-3 rounded-xl bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 group-hover:scale-110 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {item.title}
                </h3>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                  {item.desc}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  /* Utilidades de animación personalizadas */
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin-slow {
    animation: spin-slow 4s linear infinite;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out forwards;
  }

  @keyframes fade-in-down {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-down {
    animation: fade-in-down 0.6s ease-out forwards;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }
</style>
