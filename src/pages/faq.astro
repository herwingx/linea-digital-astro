---
// src/pages/faq.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import Button from "../components/ui/Button.astro";

// Datos Centralizados
const faqs = {
  planes: {
    title: "Planes Corporativos & Móviles",
    desc: "Detalles sobre contratos, plazos forzosos y beneficios Telcel.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    items: [
      { question: "¿Qué incluyen los Planes Telcel Plus?", answer: "Los Planes Telcel Plus incluyen minutos y SMS ilimitados en México, Estados Unidos y Canadá, además de redes sociales ilimitadas (WhatsApp, Facebook, X, Instagram, Snapchat y Uber) y una cantidad de Gigas para navegar libremente." },
      { question: "¿Puedo conservar mi número si me cambio a Telcel?", answer: "¡Sí! El trámite se llama Portabilidad y es totalmente gratuito. Solo necesitas tu NIP de portabilidad (envía NIP al 051) y una identificación oficial. Nosotros nos encargamos de todo el proceso en menos de 24 horas." },
      { question: "¿Cuál es la vigencia de mi plan?", answer: "Manejamos planes libres (sin plazo forzoso) y planes con equipo incluido a 12, 18, 24 o 36 meses. Tú eliges la opción que mejor se adapte a tus necesidades." },
    ]
  },
  internet: {
    title: "Internet en Casa & IoT",
    desc: "Configuración de módems, cobertura y movilidad.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />`,
    items: [
      { question: "¿Cómo funciona el Internet en Casa?", answer: "Es muy sencillo: te entregamos un módem que solo necesitas conectar a la luz y ¡listo! No requiere instalación técnica ni cableado. Funciona a través de la red 4G/5G de Telcel." },
      { question: "¿Puedo mover el módem a otra casa?", answer: "El servicio está diseñado para funcionar en una ubicación específica. Si necesitas cambiar de domicilio, debes notificarlo para actualizar la ubicación ($100 costo por cambio)." },
    ]
  },
  pagos: {
    title: "Facturación & Pagos",
    desc: "Métodos de pago aceptados, cortes y reconexiones.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />`,
    items: [
      { question: "¿Dónde puedo pagar mi factura?", answer: "Puedes pagar en nuestra app Mi Telcel, sucursales bancarias, OXXO, o domiciliar el cargo a tu tarjeta de crédito/débito para mayor comodidad." },
      { question: "¿Qué pasa si me atraso en mi pago?", answer: "El servicio podría suspenderse temporalmente. Te recomendamos domiciliar tu pago para evitar interrupciones y cargos por reconexión." },
    ]
  }
};

// Schema SEO
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: Object.values(faqs).flatMap(cat => cat.items.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  })))
};
---

<BaseLayout
  title="Centro de Ayuda | Línea Digital"
  description="Base de conocimientos para clientes y distribuidores Telcel."
>
  
  <!-- 1. HERO SEARCH SECTION -->
  <section class="relative pt-32 pb-20 px-6 overflow-hidden bg-slate-50 dark:bg-[#0B1120] border-b border-slate-200 dark:border-white/5">
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-blue-100/50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs font-bold uppercase tracking-widest mb-6 border border-blue-200 dark:border-blue-500/20">
        Soporte 24/7
      </span>
      
      <h1 class="text-4xl md:text-6xl font-black text-slate-900 dark:text-white mb-6 tracking-tight">
        ¿Cómo podemos <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">ayudarte?</span>
      </h1>
      
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 max-w-2xl mx-auto">
        Busca respuestas sobre trámites, configuraciones técnicas o dudas comerciales.
      </p>

      <!-- SEARCH BAR INTERACTIVA -->
      <div class="relative max-w-2xl mx-auto group">
        <div class="absolute inset-0 bg-blue-500/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative flex items-center bg-white dark:bg-slate-900 rounded-2xl shadow-xl shadow-slate-200/50 dark:shadow-black/50 border border-slate-200 dark:border-slate-700 focus-within:border-blue-500 focus-within:ring-4 focus-within:ring-blue-500/10 transition-all overflow-hidden">
          <div class="pl-6 text-slate-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <input 
            type="text" 
            id="faq-search" 
            placeholder="Ej: Portabilidad, Factura, APN..." 
            class="w-full h-16 px-4 bg-transparent text-lg text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none"
            autocomplete="off"
          />
          <div class="pr-2 hidden sm:block">
             <kbd class="hidden sm:inline-block px-2 py-1 text-xs font-semibold text-slate-400 bg-slate-100 dark:bg-slate-800 rounded border border-slate-200 dark:border-slate-700">ESC</kbd>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. MAIN CONTENT -->
  <section class="py-20 px-6 bg-white dark:bg-slate-950 min-h-screen">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- SIDEBAR NAV (Sticky) -->
      <div class="lg:col-span-3 hidden lg:block">
        <div class="sticky top-32 space-y-2">
          <p class="px-4 text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Categorías</p>
          {Object.entries(faqs).map(([key, category]) => (
            <a 
              href={`#${key}`} 
              class="nav-link flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 hover:text-blue-600 dark:hover:text-blue-400 transition-all border border-transparent hover:border-slate-200 dark:hover:border-slate-800"
              data-target={key}
            >
              <span>{category.title.split(' ')[0]}...</span> <!-- Short title -->
              <span class="text-xs opacity-50">{category.items.length}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- FAQ LIST -->
      <div class="lg:col-span-9 space-y-16" id="faq-container">
        
        {Object.entries(faqs).map(([key, category]) => (
          <div id={key} class="faq-category scroll-mt-32 transition-all duration-500">
            <!-- Header Categoría -->
            <div class="flex items-start gap-5 mb-8">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400 ring-1 ring-blue-100 dark:ring-white/5">
                <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <Fragment set:html={category.icon} />
                </svg>
              </div>
              <div>
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{category.title}</h2>
                <p class="mt-1 text-slate-500 dark:text-slate-400 text-lg">{category.desc}</p>
              </div>
            </div>

            <!-- Accordion Items -->
            <div class="faq-items-wrapper">
               <FAQAccordion items={category.items} />
            </div>
          </div>
        ))}

        <!-- Empty State (Hidden by default) -->
        <div id="no-results" class="hidden text-center py-20">
           <div class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-900 mb-6">
              <svg class="h-10 w-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
           </div>
           <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">No encontramos respuestas</h3>
           <p class="text-slate-500 mb-8">Intenta con otra palabra clave o contáctanos directamente.</p>
           <Button href="/contacto" variant="primary">Contactar Soporte</Button>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. FOOTER CTA -->
  <section class="py-24 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-[#0B1120] text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-6">¿Todavía con dudas?</h2>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <Button href="https://wa.me/529616189200" variant="primary" class="gap-2">
          Chat por WhatsApp
        </Button>
        <Button href="tel:9616189200" variant="secondary" class="gap-2">
          Llamar ahora
        </Button>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- LOGIC -->
  <script>
    document.addEventListener("astro:page-load", () => {
      // --- 1. BUSCADOR EN TIEMPO REAL ---
      const searchInput = document.getElementById("faq-search") as HTMLInputElement;
      const faqContainer = document.getElementById("faq-container");
      const noResults = document.getElementById("no-results");
      
      if (searchInput && faqContainer) {
        // Debounce simple para rendimiento
        let timeout: any;
        
        searchInput.addEventListener("input", (e) => {
          clearTimeout(timeout);
          timeout = setTimeout(() => {
            const term = (e.target as HTMLInputElement).value.toLowerCase().trim();
            const categories = document.querySelectorAll(".faq-category");
            let totalVisible = 0;

            categories.forEach((cat) => {
              const items = cat.querySelectorAll(".group"); // Los items del acordeón
              let hasVisibleItems = false;

              items.forEach((item) => {
                const question = item.querySelector("button span")?.textContent?.toLowerCase() || "";
                const answer = item.querySelector(".prose")?.textContent?.toLowerCase() || "";
                
                if (question.includes(term) || answer.includes(term)) {
                  (item as HTMLElement).style.display = "block";
                  hasVisibleItems = true;
                  totalVisible++;
                  // Highlight opcional: item.classList.add("ring-2", "ring-blue-200");
                } else {
                  (item as HTMLElement).style.display = "none";
                }
              });

              // Ocultar la categoría entera si no tiene items visibles
              (cat as HTMLElement).style.display = hasVisibleItems ? "block" : "none";
            });

            // Toggle Empty State
            if (noResults) {
                noResults.classList.toggle("hidden", totalVisible > 0);
            }

          }, 300); // 300ms delay
        });

        // Limpiar con ESC
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && document.activeElement === searchInput) {
                searchInput.value = "";
                searchInput.dispatchEvent(new Event("input"));
                searchInput.blur();
            }
        });
      }

      // --- 2. ACTIVE NAV SCROLL ---
      const navLinks = document.querySelectorAll(".nav-link");
      const sections = document.querySelectorAll(".faq-category");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach(link => {
               link.classList.remove("bg-blue-50", "text-blue-600", "dark:bg-blue-900/30", "dark:text-blue-400", "border-blue-200");
               if (link.getAttribute("data-target") === id) {
                   link.classList.add("bg-blue-50", "text-blue-600", "dark:bg-blue-900/30", "dark:text-blue-400", "border-blue-200");
               }
            });
          }
        });
      }, { rootMargin: "-100px 0px -60% 0px" });

      sections.forEach(section => observer.observe(section));
    });

    // Fallback
    if (document.readyState === "complete") document.dispatchEvent(new Event("astro:page-load"));
    else document.addEventListener("DOMContentLoaded", () => document.dispatchEvent(new Event("astro:page-load")));
  </script>
</BaseLayout>