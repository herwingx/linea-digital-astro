---
// src/pages/form.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";

// Definimos estilos para efectos de "Glass industrial" reutilizables
const GLASS_PANEL =
  "bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border border-slate-200/50 dark:border-slate-800/50 shadow-xl shadow-slate-200/40 dark:shadow-black/40";
const INPUT_STYLE =
  "w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3.5 text-sm font-medium text-slate-900 outline-none transition-all placeholder:text-slate-400 hover:bg-white hover:border-slate-300 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-500/10 dark:border-slate-800 dark:bg-slate-950/50 dark:text-white dark:hover:bg-slate-900 dark:focus:border-blue-500";
---

<BaseLayout
  title="Soporte y Ventas - Grupo Linea Digital"
  description="Canal exclusivo para asociados y nuevos distribuidores Telcel."
>
  <!-- BACKGROUND TECNOLÓGICO -->
  <main class="relative min-h-screen w-full overflow-hidden">
    <div class="container relative z-10 mx-auto px-4 py-16 sm:px-6 lg:py-24">
      <!-- HEADER CON JERARQUÍA B2B -->
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-blue-200/60 bg-white/50 px-3 py-1 text-[11px] font-bold uppercase tracking-widest text-blue-700 shadow-sm backdrop-blur-md dark:border-blue-900/30 dark:bg-blue-950/30 dark:text-blue-400"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"
            ></span>
          </span>
          Soporte Distribuidores Activo
        </div>

        <h1
          class="text-4xl md:text-6xl font-black tracking-tighter text-slate-900 dark:text-white mb-6"
        >
          ¿Qué vamos a <br class="hidden md:block" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400"
            >construir juntos?</span
          >
        </h1>

        <p
          class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed max-w-lg mx-auto"
        >
          Estamos listos para escalar tu negocio con tecnología móvil. Cuéntanos
          tus necesidades.
        </p>
      </div>
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-6 lg:grid-cols-12">
        <!-- COLUMNA IZQUIERDA: INFORMACIÓN Y ACCIONES RÁPIDAS (4 COLS) -->
        <div class="flex flex-col gap-6 lg:col-span-4">
          <!-- Card: WhatsApp (High Priority) -->
          <div
            class={`${GLASS_PANEL} group relative overflow-hidden rounded-2xl p-8 transition-all hover:-translate-y-1 hover:shadow-2xl`}
          >
            <div
              class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-green-500/10 blur-3xl group-hover:bg-green-500/20 transition-all"
            >
            </div>

            <h3 class="font-bold text-slate-900 dark:text-white">
              Chat Distribuidor
            </h3>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
              Canal prioritario para cierre de ventas y stock.
            </p>

            <a
              href="https://wa.me/529614603593"
              target="_blank"
              class="mt-6 flex w-full items-center justify-center gap-3 rounded-xl bg-slate-900 px-4 py-3 text-sm font-bold text-white transition-all hover:bg-slate-800 hover:shadow-lg dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
            >
              <svg
                class="h-5 w-5 text-green-500"
                fill="currentColor"
                viewBox="0 0 24 24"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.548 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path></svg
              >
              <span>Iniciar Conversación</span>
            </a>
          </div>

          <!-- Card: Contact Data -->
          <div class={`${GLASS_PANEL} flex-1 rounded-2xl p-8`}>
            <div class="space-y-8">
              <!-- Item -->
              <div class="flex gap-4">
                <div
                  class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-blue-600 dark:border-slate-800 dark:bg-slate-900 dark:text-blue-500"
                >
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                  >
                </div>
                <div>
                  <h4 class="font-semibold text-slate-900 dark:text-white">
                    Oficina Central
                  </h4>
                  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                    1a Avenida Norte Poniente #834<br />Tuxtla Gutiérrez,
                    Chiapas.
                  </p>
                </div>
              </div>

              <!-- Item -->
              <div class="flex gap-4">
                <div
                  class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-blue-600 dark:border-slate-800 dark:bg-slate-900 dark:text-blue-500"
                >
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path></svg
                  >
                </div>
                <div>
                  <h4 class="font-semibold text-slate-900 dark:text-white">
                    Email Corporativo
                  </h4>
                  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                    <a
                      href="mailto:ventas@linea-digital.com"
                      class="hover:text-blue-500 hover:underline"
                      >ventas@linea-digital.com</a
                    >
                  </p>
                </div>
              </div>
            </div>

            <!-- Mini Stats/Trust Badge -->
            <div
              class="mt-8 border-t border-slate-200 pt-6 dark:border-slate-800"
            >
              <div class="flex items-center gap-2">
                <div class="flex -space-x-2">
                  <img
                    class="h-8 w-8 rounded-full border-2 border-white dark:border-slate-900"
                    src="https://ui-avatars.com/api/?name=Telcel+D&background=0D47A1&color=fff"
                    alt="Support"
                  />
                  <img
                    class="h-8 w-8 rounded-full border-2 border-white dark:border-slate-900"
                    src="https://ui-avatars.com/api/?name=Tec+A&background=1565C0&color=fff"
                    alt="Support"
                  />
                  <img
                    class="h-8 w-8 rounded-full border-2 border-white dark:border-slate-900"
                    src="https://ui-avatars.com/api/?name=Ven+B&background=1976D2&color=fff"
                    alt="Support"
                  />
                </div>
                <p
                  class="text-xs font-medium text-slate-600 dark:text-slate-400"
                >
                  Respuesta media: <span
                    class="text-green-600 dark:text-green-400"
                    >&lt; 15 mins</span
                  >
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- COLUMNA DERECHA: FORMULARIO PRINCIPAL (8 COLS) -->
        <div class="lg:col-span-8">
          <div class={`${GLASS_PANEL} h-full rounded-2xl p-8 sm:p-12`}>
            <div class="mb-8 flex items-center justify-between">
              <h2
                class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white"
              >
                Enviar Ticket / Solicitud
              </h2>
              <span
                class="hidden rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-500 dark:bg-slate-800 sm:inline-block"
                >ID: GLD-WEB</span
              >
            </div>

            <!-- Área de Mensajes (Feedback) -->
            <div id="response-messages" class="mb-6"></div>

            <form id="contact-form" class="space-y-6">
              <!-- Grid Nombre/Teléfono -->
              <div class="grid gap-6 md:grid-cols-2">
                <div class="space-y-1.5">
                  <label
                    for="name"
                    class="ml-1 text-xs font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400"
                    >Nombre / Razón Social</label
                  >
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Ej. Distribuidora Norte"
                    class={INPUT_STYLE}
                  />
                </div>
                <div class="space-y-1.5">
                  <label
                    for="phone"
                    class="ml-1 text-xs font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400"
                    >Teléfono (WhatsApp)</label
                  >
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="961..."
                    class={INPUT_STYLE}
                  />
                </div>
              </div>

              <!-- Email -->
              <div class="space-y-1.5">
                <label
                  for="email"
                  class="ml-1 text-xs font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400"
                  >Correo Electrónico</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="contacto@empresa.com"
                  class={INPUT_STYLE}
                />
              </div>

              <!-- Tipo de Solicitud (Nuevo campo B2B) -->
              <div class="space-y-1.5">
                <label
                  for="subject"
                  class="ml-1 text-xs font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400"
                  >Departamento</label
                >
                <div class="relative">
                  <select
                    id="subject"
                    name="subject"
                    class={`${INPUT_STYLE} appearance-none cursor-pointer`}
                  >
                    <option value="ventas">Cotización de Equipos (Lote)</option>
                    <option value="activaciones"
                      >Activación de Planes / Chips</option
                    >
                    <option value="soporte">Soporte Técnico / Garantías</option>
                    <option value="otro">Otro Asunto</option>
                  </select>
                  <div
                    class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500"
                  >
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"></path></svg
                    >
                  </div>
                </div>
              </div>

              <!-- Mensaje -->
              <div class="space-y-1.5">
                <label
                  for="message"
                  class="ml-1 text-xs font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400"
                  >Detalles de la Solicitud</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  placeholder="Especifica modelos, cantidades o dudas puntuales..."
                  class={`${INPUT_STYLE} resize-none`}></textarea>
              </div>

              <!-- Footer Formulario -->
              <div
                class="flex flex-col items-center justify-between gap-4 pt-4 sm:flex-row"
              >
                <p class="text-xs text-slate-400">
                  <span class="text-blue-600 dark:text-blue-400">*</span> Campos
                  requeridos para proceso B2B.
                </p>
                <Button
                  type="submit"
                  variant="primary"
                  size="lg"
                  class="w-full shadow-lg shadow-blue-600/20 sm:w-auto"
                >
                  <span class="flex items-center gap-2">
                    Enviar Solicitud
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                    >
                  </span>
                </Button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Lógica optimizada del formulario (mantenemos la robustez original con pequeñas mejoras de UX)
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("contact-form") as HTMLFormElement;
      const responseMessages = document.getElementById("response-messages");

      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const submitButton = form.querySelector(
            'button[type="submit"]',
          ) as HTMLButtonElement;
          const originalContent = submitButton.innerHTML;

          // Estado de carga UI
          submitButton.disabled = true;
          submitButton.classList.add("opacity-80", "cursor-wait");
          submitButton.innerHTML = `<div class="flex items-center gap-2"><svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Procesando...</span></div>`;

          const formData = new FormData(form);
          const data = Object.fromEntries(formData.entries());

          try {
            // Simulación de delay de red para UX (quitar en producción si es instantáneo)
            await new Promise((r) => setTimeout(r, 800));

            const response = await fetch("/api/send-email", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(data),
            });

            const result = await response.json();

            if (!response.ok)
              throw new Error(result.error || "Error de conexión");

            // Feedback Éxito Enterprise
            if (responseMessages) {
              responseMessages.innerHTML = `
                <div class="flex items-start gap-4 rounded-xl border border-green-200 bg-green-50/80 p-4 text-green-800 backdrop-blur-sm dark:border-green-900/30 dark:bg-green-900/20 dark:text-green-300 animate-fade-in-up">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <div>
                    <h4 class="text-sm font-bold">Solicitud Enviada Correctamente</h4>
                    <p class="text-sm mt-1 opacity-90">${result.message || "Un ejecutivo comercial te contactará en breve."}</p>
                  </div>
                </div>`;
            }
            form.reset();
          } catch (error) {
            // Feedback Error
            if (responseMessages) {
              responseMessages.innerHTML = `
                <div class="flex items-start gap-4 rounded-xl border border-red-200 bg-red-50/80 p-4 text-red-800 backdrop-blur-sm dark:border-red-900/30 dark:bg-red-900/20 dark:text-red-300 animate-fade-in-up">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <div>
                    <h4 class="text-sm font-bold">Error en el envío</h4>
                    <p class="text-sm mt-1 opacity-90">${error instanceof Error ? error.message : "Intenta contactarnos por WhatsApp."}</p>
                  </div>
                </div>`;
            }
          } finally {
            submitButton.disabled = false;
            submitButton.classList.remove("opacity-80", "cursor-wait");
            submitButton.innerHTML = originalContent;

            // Scroll suave hacia el mensaje si está fuera de vista
            responseMessages?.scrollIntoView({
              behavior: "smooth",
              block: "center",
            });
          }
        });
      }
    });
  </script>
</BaseLayout>
